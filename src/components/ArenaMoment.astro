<script>
	const terminal = document.querySelector("[data-mission-terminal]");

	if (terminal instanceof HTMLElement) {
		const shouldUseBottomUpReveal = document.body.dataset.scrollFlow === "bottom-up" && !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		if (shouldUseBottomUpReveal) {
			terminal.classList.remove("is-visible", "motion-ready", "is-bottom-up-revealed");

			let lastScrollY = window.scrollY;
			let hasMovedTowardTerminal = false;
			let revealQueued = false;
			const revealFromBottomUp = () => {
				const currentScrollY = window.scrollY;
				const isScrollingUpDocument = currentScrollY < lastScrollY - 2;
				lastScrollY = currentScrollY;

				if (isScrollingUpDocument) {
					hasMovedTowardTerminal = true;
				}

				if (terminal.classList.contains("is-bottom-up-revealed") || !hasMovedTowardTerminal) {
					revealQueued = false;
					return;
				}

				const rect = terminal.getBoundingClientRect();
				const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
				const hasEnteredFromTop = rect.top < viewportHeight * 0.64 && rect.bottom > viewportHeight * 0.46;

				if (hasEnteredFromTop) {
					terminal.classList.add("is-bottom-up-revealed");
				}

				revealQueued = false;
			};

			const requestRevealCheck = () => {
				if (!revealQueued) {
					revealQueued = true;
					window.requestAnimationFrame(revealFromBottomUp);
				}
			};

			window.setTimeout(() => {
				terminal.classList.remove("is-visible", "motion-ready", "is-bottom-up-revealed");
				lastScrollY = window.scrollY;
				hasMovedTowardTerminal = false;
			}, 450);

			window.addEventListener("scroll", requestRevealCheck, { passive: true });
		} else {
			terminal.classList.add("is-bottom-up-revealed");
		}

		const tabs = Array.from(terminal.querySelectorAll("[data-mission-tab]"));
		const panels = Array.from(terminal.querySelectorAll("[data-mission-panel]"));
		const display = terminal.querySelector(".mission-display");
		const mobileMissionLayout = window.matchMedia("(max-width: 920px)");
		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		tabs.forEach((tab) => {
			if (!(tab instanceof HTMLButtonElement)) return;

			tab.addEventListener("click", () => {
				const targetMission = tab.dataset.missionTab;
				if (!targetMission) return;

				terminal.dataset.activeMission = targetMission;

				tabs.forEach((candidate) => {
					if (!(candidate instanceof HTMLButtonElement)) return;
					const isActive = candidate.dataset.missionTab === targetMission;
					candidate.classList.toggle("is-active", isActive);
					candidate.setAttribute("aria-selected", isActive ? "true" : "false");
				});

				panels.forEach((panel) => {
					if (!(panel instanceof HTMLElement)) return;
					panel.classList.toggle("is-active", panel.dataset.missionPanel === targetMission);
				});

				if (display instanceof HTMLElement && mobileMissionLayout.matches) {
					display.scrollIntoView({
						behavior: reducedMotion.matches ? "auto" : "smooth",
						block: "start",
					});
				}
			});
		});
	}
</script>
