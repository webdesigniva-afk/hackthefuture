---
const challenges = [
	{
		title: "Future of Work",
		question: "How does Shumen become a place where young people build their future?",
		description: "AI, automation, and new industries are changing what jobs exist and what skills matter. What should the path from school to work actually look like in your region?",
		ideas: [
			"Youth career platform",
			"New internship model",
			"Campaign for local opportunities",
			"Tool connecting young people with companies",
		],
	},
	{
		title: "Environment & Crisis Response",
		question: "How does Bulgaria react faster to fires, floods, and emergencies?",
		description: "Climate is hitting harder and faster. Communities need better tools to prepare, respond, and protect each other.",
		ideas: [
			"Digital volunteer system",
			"Crisis communication plan",
			"Early-warning sensor concept",
			"Emergency map",
			"Public preparedness campaign",
		],
	},
	{
		title: "Mental Health & Youth Wellbeing",
		question: "How does a city actually take care of young people's mental health?",
		description: "Anxiety, isolation, pressure, and burnout are affecting young people more than ever.",
		ideas: [
			"Peer-support platform",
			"School-based program",
			"Anti-stigma campaign",
			"Digital wellbeing tool",
			"Municipality proposal",
		],
	},
	{
		title: "Local Products & Future Business",
		question: "How does Bulgaria turn local strengths into future opportunities?",
		description: "Bulgaria has strong local products, food traditions, and creative people, but many producers struggle to reach younger consumers and markets.",
		ideas: [
			"Digital marketplace",
			"Brand campaign",
			"Tourism-food experience",
			"Packaging concept",
			"Platform connecting producers",
		],
	},
];
---

<section id="challenges" class="motion-section arena-moment civic-grid px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
	<div class="mx-auto max-w-7xl">
		<div class="mb-9 grid gap-6 lg:grid-cols-[minmax(12rem,0.34fr)_minmax(0,1fr)] lg:items-end">
			<p class="arena-kicker">PILOT EDITION</p>
			<div>
				<h2 class="arena-statement">Four real challenges. One future to build.</h2>
				<p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-muted)]">
					Choose one of four questions Bulgaria is already facing. Spend two days building something that could become part of the answer.
				</p>
			</div>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{challenges.map((challenge, index) => (
				<details class="challenge-card group relative overflow-hidden rounded-[1rem] border border-[var(--color-line)] bg-white/80 shadow-[0_14px_44px_rgba(10,10,10,0.045)] transition duration-300 ease-[var(--ease-premium)] hover:-translate-y-0.5 hover:border-[rgba(124,255,107,0.42)] hover:bg-white hover:shadow-[0_20px_58px_rgba(10,10,10,0.1)]">
					<div class="absolute right-5 top-4 text-xs font-semibold text-[var(--color-purple)]/44 transition duration-300 group-hover:text-[var(--color-purple-soft)]">
						0{index + 1}
					</div>
					<summary class="challenge-summary flex min-h-[9.5rem] cursor-pointer list-none flex-col justify-between gap-5 p-5 marker:hidden sm:p-6">
						<div class="h-0.5 w-10 bg-[linear-gradient(90deg,var(--color-ink),var(--color-accent))] opacity-60 transition-all duration-300 group-hover:w-14 group-hover:opacity-85 group-hover:shadow-[0_0_18px_rgba(124,255,107,0.18)]" aria-hidden="true"></div>
						<div>
							<h3 class="max-w-xl text-xl font-semibold leading-tight tracking-[-0.025em] text-[var(--color-ink)] sm:text-2xl">
								{challenge.title}
							</h3>
							<p class="mt-3 max-w-xl text-sm leading-6 text-[var(--color-muted)] sm:text-base sm:leading-7">
								{challenge.question}
							</p>
							<p class="mt-4 inline-flex items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-purple)]/62">
								<span class="challenge-toggle-icon grid h-5 w-5 place-items-center rounded-full border border-[var(--color-line)] text-[var(--color-purple)] transition duration-300" aria-hidden="true">+</span>
								Explore
							</p>
						</div>
					</summary>
					<div class="challenge-expansion">
						<div class="challenge-expansion-inner px-5 pb-5 sm:px-6 sm:pb-6">
							<p class="border-t border-[var(--color-line)] pt-4 text-sm leading-7 text-[var(--color-muted)]">
								{challenge.description}
							</p>
							<div class="mt-4">
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-purple)]/68">
									Possible ideas
								</p>
								<ul class="mt-3 grid gap-1.5 sm:grid-cols-2">
									{challenge.ideas.map((idea) => (
										<li class="flex items-start gap-2.5 text-sm leading-6 text-[var(--color-muted)]">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-gold)]/72" aria-hidden="true"></span>
											<span>{idea}</span>
										</li>
									))}
								</ul>
							</div>
						</div>
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.challenge-summary::-webkit-details-marker {
		display: none;
	}

	.challenge-expansion {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		transition:
			grid-template-rows 360ms var(--ease-premium),
			opacity 260ms var(--ease-premium);
	}

	.challenge-expansion-inner {
		overflow: hidden;
	}

	.challenge-card[open] .challenge-expansion {
		grid-template-rows: 1fr;
		opacity: 1;
	}

	.challenge-card[open] .challenge-toggle-icon {
		rotate: 45deg;
		border-color: rgba(0, 255, 65, 0.54);
		background: rgba(0, 255, 65, 0.1);
		box-shadow: 0 0 22px rgba(0, 255, 65, 0.12);
	}
</style>
