	<div class="mx-auto max-w-7xl">
		<div class="mission-heading mx-auto mb-5 max-w-[1100px] text-center sm:mb-6">
			<p class="arena-kicker">{copy.kicker}</p>
			<h2 class="mission-heading-title mt-2.5">
				<span>{copy.titleA}</span>
				<span>{copy.titleB} <span class="mission-heading-accent">{copy.titleAccent}</span> {copy.titleC}</span>
			</h2>
			<p class="mx-auto mt-3.5 max-w-2xl text-base leading-7 text-[var(--color-muted)] sm:mt-4">
				{copy.introA}
				<br class="hidden sm:block" />
				{copy.introB}
			</p>
		</div>

		<div class="mission-terminal" data-mission-terminal data-active-mission="1">
			<span class="mission-reveal-sweep" aria-hidden="true"></span>
