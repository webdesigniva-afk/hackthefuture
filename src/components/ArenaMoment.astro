						<span>{copy.indexLabel}</span>
					</div>
					<div class="mission-tabs" role="tablist" aria-label="Challenge missions">
						{challenges.map((challenge, index) => (
							<button
								class={`mission-tab ${index === 0 ? "is-active" : ""}`}
								type="button"
								role="tab"
								aria-selected={index === 0 ? "true" : "false"}
								aria-controls={`mission-panel-${index + 1}`}
								id={`mission-tab-${index + 1}`}
								data-mission-tab={index + 1}
							>
								<span class="mission-tab-code">{challenge.mission}</span>
								<span class="mission-tab-title">{challenge.title}</span>
								<span class="mission-tab-signal" aria-hidden="true"></span>
							</button>
						))}
					</div>
				</nav>

				<div class="mission-display">
					<div class="mission-display-frame" aria-hidden="true">
						<span></span>
						<span></span>
