---
import { getLang, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const cookieCopy = {
	en: {
		kicker: "Cookie Policy",
		title: "Cookie Policy",
		updated: "Last updated: June 2026",
		intro: [
			"This website uses cookies and similar technologies to help the site function properly and to understand how visitors use it.",
		],
		blocks: [
			{
				index: "01",
				title: "What Are Cookies?",
				paragraphs: [
					"Cookies are small text files stored on your device when you visit a website.",
					"They help websites remember information about your visit and improve your browsing experience.",
				],
			},
			{
				index: "02",
				title: "How We Use Cookies",
				paragraphs: ["We may use cookies to:"],
				list: [
					"Ensure the website functions correctly",
					"Improve performance and user experience",
					"Understand how visitors interact with the website",
					"Measure website traffic and engagement",
				],
			},
			{
				index: "03",
				title: "Analytics",
				paragraphs: [
					"We may use analytics tools to understand how people use the website.",
					"This information helps us improve the experience for future visitors and participants.",
					"Analytics data is used in aggregate form wherever possible.",
				],
			},
			{
				index: "04",
				title: "Managing Cookies",
				paragraphs: [
					"Most web browsers allow you to control, block, or delete cookies through your browser settings.",
					"Please note that disabling certain cookies may affect how some parts of the website function.",
				],
			},
			{
				index: "05",
				title: "Contact",
				paragraphs: ["If you have any questions about this Cookie Policy, please contact:"],
				email: "social@catalizator.org",
			},
		],
	},
	bg: {
		kicker: "ПОЛИТИКА ЗА БИСКВИТКИ",
		title: "Политика за бисквитки",
		updated: "Последна актуализация: юни 2026 г.",
		intro: [
			"Този уебсайт използва бисквитки и сходни технологии, за да функционира коректно и за да ни помогне да разберем как посетителите го използват.",
		],
		blocks: [
			{
				index: "01",
				title: "Какво представляват бисквитките?",
				paragraphs: [
					"Бисквитките са малки текстови файлове, които се съхраняват на вашето устройство при посещение на уебсайт.",
					"Те помагат на сайтовете да запомнят информация за вашето посещение и да подобрят потребителското изживяване.",
				],
			},
			{
				index: "02",
				title: "Как използваме бисквитките",
				paragraphs: ["Можем да използваме бисквитки, за да:"],
				list: [
					"Осигурим правилното функциониране на уебсайта",
					"Подобрим неговата производителност и потребителско изживяване",
					"Разберем как посетителите взаимодействат със сайта",
					"Измерваме посещаемостта и ангажираността на потребителите",
				],
			},
			{
				index: "03",
				title: "Анализ на използването",
				paragraphs: [
					"Можем да използваме инструменти за анализ, за да разберем как хората използват уебсайта.",
					"Тази информация ни помага да подобряваме изживяването на бъдещите посетители и участници.",
					"Когато е възможно, данните се използват в обобщен и анонимизиран вид.",
				],
			},
			{
				index: "04",
				title: "Управление на бисквитките",
				paragraphs: [
					"Повечето интернет браузъри ви позволяват да управлявате, ограничавате или изтривате бисквитките чрез настройките си.",
					"Моля, имайте предвид, че деактивирането на определени бисквитки може да повлияе на работата на някои части от уебсайта.",
				],
			},
			{
				index: "05",
				title: "Контакт",
				paragraphs: ["Ако имате въпроси относно тази Политика за бисквитките, можете да се свържете с нас на:"],
				email: "social@catalizator.org",
			},
		],
	},
}[lang];
const privacyCopy = {
	en: {
		kicker: "Privacy Policy",
		title: "Privacy Policy",
		updated: "Last updated: June 2026",
		intro: [
			"At Hack The Future, we believe trust matters. This Privacy Policy explains what information we collect, why we collect it, and how we use it.",
			"By using this website or submitting an application, you agree to the practices described below.",
		],
		blocks: [
			{
				index: "01",
				title: "Who We Are",
				paragraphs: [
					"Hack The Future is an educational initiative designed to help young people explore real-world challenges, develop practical skills, and connect with mentors, institutions, and future opportunities.",
					"If you have any questions about this Privacy Policy, you can contact us at:",
				],
				emailPrefix: "Email:",
				email: "social@catalizator.org",
			},
			{
				index: "02",
				title: "Information We Collect",
				paragraphs: ["When you submit an application through the website, we may collect:"],
				list: [
					"Name",
					"Email address",
					"Age",
					"School",
					"Your answer to \"Why are you keen to join?\"",
					"Your selected challenge theme",
					"Whether you are applying individually or as part of a team",
				],
				after: [
					"We may also collect limited technical information when you visit the website, such as browser type, device information, and general website usage data.",
				],
			},
			{
				index: "03",
				title: "How We Use Your Information",
				paragraphs: ["We use the information you provide to:"],
				list: [
					"Review and evaluate applications",
					"Communicate with applicants and participants",
					"Organize the event and participant experience",
					"Create teams where appropriate",
					"Share important updates related to Hack The Future",
					"Improve future editions of the programme and website",
				],
				after: ["We only collect information that is relevant to running the programme and supporting participants."],
			},
			{
				index: "04",
				title: "Photography and Event Media",
				paragraphs: [
					"During Hack The Future, photographs and video recordings may be taken during event activities.",
					"These may be used to document the event, celebrate participants, and share the story of the programme through websites, social media, reports, and partner communications.",
					"Where appropriate, additional consent may be requested before specific media is used.",
				],
			},
			{
				index: "05",
				title: "Sharing Information",
				paragraphs: [
					"We do not sell personal information.",
					"Information may be shared with trusted organisers, mentors, partners, and service providers only when necessary to operate and deliver the programme.",
					"Any such sharing is limited to what is reasonably required for event administration and participant support.",
				],
			},
			{
				index: "06",
				title: "Data Retention",
				paragraphs: [
					"We keep personal information only for as long as reasonably necessary to manage applications, deliver the programme, communicate with participants, and maintain records related to the initiative.",
					"When information is no longer needed, it will be securely deleted or anonymised.",
				],
			},
			{
				index: "07",
				title: "Your Rights",
				paragraphs: [
					"You may request access to the personal information we hold about you, ask for corrections, or request deletion of your information where appropriate.",
					"To make a request, please contact:",
				],
				email: "social@catalizator.org",
			},
			{
				index: "08",
				title: "Changes to This Policy",
				paragraphs: [
					"We may update this Privacy Policy from time to time.",
					"Any updates will be published on this page together with the revised date shown above.",
				],
			},
		],
	},
	bg: {
		kicker: "ПОЛИТИКА ЗА ПОВЕРИТЕЛНОСТ",
		title: "Политика за поверителност",
		updated: "Последна актуализация: юни 2026 г.",
		intro: [
			"В Hack The Future вярваме, че доверието е важно. Настоящата Политика за поверителност обяснява каква информация събираме, защо я събираме и как я използваме.",
			"Използвайки този уебсайт или изпращайки кандидатура, вие се съгласявате с описаните по-долу практики.",
		],
		blocks: [
			{
				index: "01",
				title: "Кои сме ние",
				paragraphs: [
					"Hack The Future е образователна инициатива, създадена, за да помогне на младите хора да изследват реални обществени предизвикателства, да развиват практически умения и да се свързват с ментори, институции и бъдещи възможности.",
					"За въпроси относно настоящата политика можете да се свържете с нас на:",
				],
				emailPrefix: "Имейл:",
				email: "social@catalizator.org",
			},
			{
				index: "02",
				title: "Каква информация събираме",
				paragraphs: ["При кандидатстване чрез уебсайта можем да събираме:"],
				list: [
					"Име",
					"Имейл адрес",
					"Възраст",
					"Училище",
					"Отговор на въпроса „Защо искаш да участваш?“",
					"Избрано предизвикателство",
					"Информация дали кандидатствате самостоятелно или като част от екип",
				],
				after: [
					"При посещение на сайта може да събираме и ограничена техническа информация като тип браузър, информация за устройството и обобщени данни за използването на уебсайта.",
				],
			},
			{
				index: "03",
				title: "Как използваме информацията",
				paragraphs: ["Използваме предоставената информация, за да:"],
				list: [
					"Разглеждаме и оценяваме кандидатурите",
					"Комуникираме с кандидати и участници",
					"Организираме събитието и участническото преживяване",
					"Сформираме екипи, когато това е необходимо",
					"Изпращаме важна информация, свързана с Hack The Future",
					"Подобряваме бъдещи издания на програмата и уебсайта",
				],
				after: ["Събираме единствено информация, необходима за провеждането на инициативата и подкрепата на участниците."],
			},
			{
				index: "04",
				title: "Снимки и видео по време на събитието",
				paragraphs: [
					"По време на Hack The Future могат да бъдат правени снимки и видеозаписи.",
					"Те могат да бъдат използвани за документиране на събитието, представяне на участниците и разказване на историята на инициативата чрез уебсайтове, социални мрежи, отчети и комуникация с партньори.",
					"Когато е необходимо, може да бъде поискано допълнително съгласие за използването на конкретни изображения или видеоматериали.",
				],
			},
			{
				index: "05",
				title: "Споделяне на информация",
				paragraphs: [
					"Ние не продаваме лични данни.",
					"Информация може да бъде споделяна с организатори, ментори, партньори и доставчици на услуги само когато това е необходимо за организирането и провеждането на програмата.",
					"Подобно споделяне е ограничено до информацията, която е разумно необходима за администрирането на събитието и подкрепата на участниците.",
				],
			},
			{
				index: "06",
				title: "Съхранение на данни",
				paragraphs: [
					"Съхраняваме лична информация само толкова дълго, колкото е разумно необходимо за обработката на кандидатурите, провеждането на програмата, комуникацията с участниците и поддържането на архив, свързан с инициативата.",
					"Когато информацията вече не е необходима, тя се изтрива или анонимизира по сигурен начин.",
				],
			},
			{
				index: "07",
				title: "Вашите права",
				paragraphs: [
					"Можете да поискате достъп до личната информация, която съхраняваме за вас, да поискате корекция на неточни данни или изтриване на информацията, когато това е приложимо.",
					"За подобни искания можете да се свържете с нас на:",
				],
				email: "social@catalizator.org",
			},
			{
				index: "08",
				title: "Промени в тази политика",
				paragraphs: [
					"Възможно е периодично да актуализираме настоящата Политика за поверителност.",
					"Всички промени ще бъдат публикувани на тази страница заедно с датата на последната актуализация.",
				],
			},
		],
	},
}[lang];
const heroCopy = {
	en: {
		kicker: "Privacy & Cookies",
		statusStack: ["DATA USE", "CONSENT", "COOKIES"],
		protocol: "TRANSPARENCY PROTOCOL // JUNE 2026",
		title: "Trust, data, and cookies.",
		intro: "How Hack The Future handles application information, event media, website data, and cookies.",
		linksLabel: "Legal page sections",
		privacyLink: "Privacy Policy",
		cookiesLink: "Cookie Policy",
	},
	bg: {
		kicker: "ПОВЕРИТЕЛНОСТ И БИСКВИТКИ",
		statusStack: ["ИЗПОЛЗВАНЕ НА ДАННИ", "СЪГЛАСИЕ", "БИСКВИТКИ"],
		protocol: "ПРОТОКОЛ ЗА ПРОЗРАЧНОСТ // ЮНИ 2026",
		title: "Доверие, данни и бисквитки.",
		intro: "Как Hack The Future обработва информацията от кандидатурите, съдържанието от събитието, данните за използването на уебсайта и бисквитките.",
		linksLabel: "Секции на правната страница",
		privacyLink: "Политика за поверителност",
		cookiesLink: "Политика за бисквитки",
	},
}[lang];
---

<section id="cookies" class="legal-section legal-section--cookies px-4 py-16 sm:px-6 sm:py-20 lg:px-8" data-legal-lang={lang}>
	<div class="legal-shell mx-auto max-w-6xl">
		<div class="legal-section-heading">
			<h2>{cookieCopy.title}</h2>
			<p class="legal-updated">{cookieCopy.updated}</p>
		</div>

		<div class="legal-content">
			<div class="legal-block">
				{cookieCopy.intro.map((paragraph) => <p>{paragraph}</p>)}
			</div>

			{cookieCopy.blocks.map((block) => (
				<div class="legal-block">
					<p class="legal-block-index">{block.index}</p>
					<h3>{block.title}</h3>
					{block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					{"list" in block && block.list && (
						<ul>
							{block.list.map((item) => <li>{item}</li>)}
						</ul>
					)}
					{"email" in block && block.email && (
						<p><a href={`mailto:${block.email}`}><strong>{block.email}</strong></a></p>
					)}
				</div>
			))}
		</div>
	</div>
</section>

<section id="privacy" class="legal-section px-4 py-16 sm:px-6 sm:py-20 lg:px-8" data-legal-lang={lang}>
	<div class="legal-shell mx-auto max-w-6xl">
		<div class="legal-section-heading">
			<h2>{privacyCopy.title}</h2>
			<p class="legal-updated">{privacyCopy.updated}</p>
		</div>

		<div class="legal-content">
			<div class="legal-block">
				{privacyCopy.intro.map((paragraph) => <p>{paragraph}</p>)}
			</div>

			{privacyCopy.blocks.map((block) => (
				<div class="legal-block">
					<p class="legal-block-index">{block.index}</p>
					<h3>{block.title}</h3>
					{block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					{"list" in block && block.list && (
						<ul>
							{block.list.map((item) => <li>{item}</li>)}
						</ul>
					)}
					{"after" in block && block.after && block.after.map((paragraph) => <p>{paragraph}</p>)}
					{"email" in block && block.email && (
						<p>
							{"emailPrefix" in block && block.emailPrefix && <><strong>{block.emailPrefix}</strong>{" "}</>}
							<a href={`mailto:${block.email}`}><strong>{block.email}</strong></a>
						</p>
					)}
				</div>
			))}
		</div>
	</div>
</section>

<section class="legal-hero civic-grid px-4 pb-16 pt-24 sm:px-6 sm:pb-20 sm:pt-28 lg:px-8" data-legal-hero-lang={lang}>
	<div class="legal-hero-frame mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(10rem,0.26fr)_minmax(0,1fr)]">
		<span class="legal-corner legal-corner--tl" aria-hidden="true"></span>
		<span class="legal-corner legal-corner--br" aria-hidden="true"></span>
		<div class="legal-hero-aside">
			<p class="section-kicker">{heroCopy.kicker}</p>
			<div class="legal-status-stack" aria-hidden="true">
				{heroCopy.statusStack.map((item) => <span>{item}</span>)}
			</div>
		</div>
		<div class="legal-hero-copy">
			<div class="legal-status-line" aria-hidden="true">
				<span class="legal-status-dot"></span>
				<span>{heroCopy.protocol}</span>
			</div>
			<h1>{heroCopy.title}</h1>
			<p class="legal-intro">
				{heroCopy.intro}
			</p>
			<div class="legal-jump-links" aria-label={heroCopy.linksLabel}>
				<a href="#privacy">{heroCopy.privacyLink}</a>
				<a href="#cookies">{heroCopy.cookiesLink}</a>
			</div>
		</div>
		<div class="legal-data-seal" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
		</div>
	</div>
</section>

<style>
	.legal-hero {
		position: relative;
		overflow: hidden;
		min-height: min(55rem, 100svh);
		display: grid;
		align-items: center;
		border-top: 1px solid var(--color-line);
		background:
			linear-gradient(90deg, rgba(109, 40, 217, 0.055) 1px, transparent 1px),
			linear-gradient(180deg, rgba(109, 40, 217, 0.04) 1px, transparent 1px);
		background-size: 5.25rem 5.25rem;
		background-position: center;
	}

	.legal-hero::before {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.78) 48%, rgba(255, 255, 255, 0.96) 100%),
			radial-gradient(ellipse at 68% 38%, rgba(167, 139, 250, 0.12), transparent 42%);
		content: "";
		pointer-events: none;
	}

	.legal-hero::after {
		position: absolute;
		right: 10vw;
		bottom: clamp(6rem, 12vh, 9rem);
		width: min(38vw, 30rem);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(109, 40, 217, 0.32), transparent);
		content: "";
		opacity: 0.72;
		pointer-events: none;
	}

	.legal-hero-frame {
		position: relative;
		z-index: 1;
		width: 100%;
		border-top: 1px solid color-mix(in srgb, var(--color-line) 68%, transparent);
		border-bottom: 1px solid color-mix(in srgb, var(--color-line) 68%, transparent);
		margin-bottom: clamp(1rem, 4vh, 3rem);
		padding: clamp(2.25rem, 4.5vw, 4.25rem) clamp(0rem, 1vw, 1rem);
	}

	.legal-corner {
		position: absolute;
		width: 2.6rem;
		height: 2.6rem;
		border-color: rgba(109, 40, 217, 0.34);
		pointer-events: none;
	}

	.legal-corner--tl {
		top: -1px;
		left: 0;
		border-top: 1px solid;
		border-left: 1px solid;
	}

	.legal-corner--br {
		right: 0;
		bottom: -1px;
		border-right: 1px solid;
		border-bottom: 1px solid;
	}

	.legal-hero-aside {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: clamp(6.5rem, 18vw, 13rem);
		min-height: 100%;
		padding-top: 0.35rem;
	}

	.legal-status-stack {
		display: grid;
		gap: 0.38rem;
		color: color-mix(in srgb, var(--color-muted) 48%, transparent);
		font-family: var(--font-ui);
		font-size: 0.62rem;
		font-weight: 750;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.legal-hero-copy {
		position: relative;
		z-index: 2;
		max-width: 55rem;
		padding-right: clamp(1rem, 9vw, 8rem);
	}

	.legal-status-line {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 1.25rem;
		color: color-mix(in srgb, var(--color-muted) 66%, transparent);
		font-family: var(--font-ui);
		font-size: 0.68rem;
		font-weight: 750;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.legal-status-dot {
		width: 0.46rem;
		height: 0.46rem;
		border-radius: 999px;
		background: var(--color-purple);
		box-shadow: 0 0 0 5px rgba(109, 40, 217, 0.09), 0 0 18px rgba(109, 40, 217, 0.34);
	}

	.legal-hero h1 {
		margin: 0;
		max-width: 11.5ch;
		color: var(--color-ink);
		font-family: var(--font-ui);
