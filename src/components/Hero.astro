---
import { getLang, siteCopy, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const t = siteCopy[lang].hero;
---

<section class="hero-section gradient-rule atmospheric-section civic-grid relative overflow-hidden px-4 pb-14 pt-5 sm:px-6 sm:pb-16 lg:px-8" data-future-hero>
	<canvas class="hero-code-rain" data-hero-code-rain aria-hidden="true"></canvas>

	<div class="relative z-10 mx-auto max-w-7xl">
		<div class="hero-caption mb-8 flex flex-wrap items-center gap-x-5 gap-y-2 border-y border-[rgba(10,10,10,0.11)] py-4 text-[0.63rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-ink)]/70 lg:flex-nowrap lg:justify-between lg:gap-x-10 xl:gap-x-16">
			{t.caption.map((item, index) => (
				<span class="hero-caption-unit" data-caption-unit={index + 1}>
					{index > 0 && <span class="hero-caption-separator text-[var(--color-gold)]/55" aria-hidden="true">&middot;</span>}
					<span class="hero-caption-item" data-caption-item={index + 1}>{item}</span>
				</span>
			))}
		</div>

		<div class="hero-layout grid min-h-[calc(100vh-10.5rem)] gap-5 lg:grid-cols-[minmax(0,0.92fr)_minmax(23rem,0.78fr)] lg:items-center">
			<div class="hero-intro-panel relative z-10 flex flex-col justify-center p-7 sm:p-9 lg:p-12">
				<div class="hero-platform mb-8 flex items-center gap-3.5 text-[0.67rem] font-semibold uppercase tracking-[0.2em] text-[var(--color-muted)]/82">
					<img
						src="/catalizator-logo.png"
						alt=""
						class="h-8 w-8 shrink-0 object-contain mix-blend-multiply"
						loading="eager"
						decoding="async"
					/>
					<span class="grid gap-1">
						<span class="hero-platform-title text-[0.72rem]" data-platform-matrix-title aria-label="Hack The Future"></span>
						<span>{t.platform}</span>
					</span>
				</div>

				<h1 class="hero-title max-w-[10.6em] text-[clamp(2rem,3.68vw,4.34rem)] font-[580] leading-[1.045] tracking-[-0.036em] text-[var(--color-ink)]">
					{t.title}
				</h1>

				<p class="hero-copy mt-8 max-w-3xl text-base leading-8 text-[var(--color-muted)]/94 sm:text-[1rem]">
					{t.intro}
				</p>
			</div>

			<div class="relative z-10 grid gap-5 lg:self-center">
				<div class="media-placeholder cinematic-frame image-card min-h-[28rem] rounded-[1.1rem]">
					<video
						class="media-video"
						src="/hack-the-future-hero.mp4"
						autoplay
						muted
						loop
						playsinline
						preload="metadata"
						aria-label={t.videoLabel}
					></video>
				</div>

				<div class="min-h-12 sm:min-h-14 lg:hidden" aria-hidden="true"></div>
			</div>
		</div>
	</div>

	<div class="hero-position-cue" aria-hidden="true">
		<span>NOW: YOU ARE HERE DOWN</span>
		<span class="hero-position-arrow">↑</span>
		<span>SCROLL UP TO THE FUTURE</span>
	</div>
</section>

<script>
	const hero = document.querySelector("[data-future-hero]");
	const canvas = document.querySelector("[data-hero-code-rain]");
	const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (hero instanceof HTMLElement) {
		let ticking = false;
		const updateHeroLift = () => {
			const rect = hero.getBoundingClientRect();
			const progress = Math.min(1, Math.max(0, -rect.top / Math.max(1, rect.height * 0.52)));
			hero.style.setProperty("--hero-lift", `${-progress * 34}px`);
			hero.style.setProperty("--hero-cue-opacity", `${Math.max(0, 1 - progress * 2.4)}`);
			ticking = false;
		};

		const requestHeroLift = () => {
			if (!ticking) {
				window.requestAnimationFrame(updateHeroLift);
				ticking = true;
			}
		};

		updateHeroLift();
		window.addEventListener("scroll", requestHeroLift, { passive: true });
		window.addEventListener("resize", requestHeroLift, { passive: true });
	}

	if (canvas instanceof HTMLCanvasElement) {
		const context = canvas.getContext("2d", { alpha: true });
		const symbols = ["0", "1", "A", "F", "X", "/", "{", "}", "S", "Y", "C", "D", "E"];
		let width = 0;
		let height = 0;
		let columns = [];
		let fontSize = 16;
		let animationFrame = 0;
		let lastFrame = 0;

		const resize = () => {
			const ratio = Math.min(window.devicePixelRatio || 1, 1.5);
			const rect = canvas.getBoundingClientRect();
			width = Math.max(1, Math.floor(rect.width));
			height = Math.max(1, Math.floor(rect.height));
			canvas.width = Math.floor(width * ratio);
			canvas.height = Math.floor(height * ratio);

			if (context) {
				context.setTransform(ratio, 0, 0, ratio, 0, 0);
			}

			fontSize = window.innerWidth < 768 ? 18 : 16;
			const density = window.innerWidth < 768 ? 0.24 : 0.38;
			const count = Math.max(10, Math.floor((width / fontSize) * density));
			columns = Array.from({ length: count }, (_, index) => ({
				x: window.innerWidth < 768
					? ((index + Math.random() * 0.8) / count) * width
					: width * (0.08 + ((index + Math.random() * 0.8) / count) * 0.48),
				y: Math.random() * height,
				speed: 0.14 + Math.random() * 0.24,
				alpha: 0.2 + Math.random() * 0.12,
				phase: Math.random() * Math.PI * 2,
			}));

		};

		const drawStatic = () => {
			if (!context) return;
			context.clearRect(0, 0, width, height);
			context.font = `${fontSize}px Arial, sans-serif`;
			context.shadowColor = "rgba(0, 255, 65, 0.16)";
			context.shadowBlur = 4;
			context.fillStyle = "rgba(0, 125, 40, 0.22)";
			columns.forEach((column, columnIndex) => {
				for (let y = columnIndex % 3 * fontSize; y < height; y += fontSize * 7) {
					context.fillText(symbols[Math.floor(columnIndex + y) % symbols.length], column.x, y);
				}
			});
			context.shadowBlur = 0;
		};

		const drawFrame = (time) => {
			if (!context) return;
			if (time - lastFrame < 42) {
				animationFrame = window.requestAnimationFrame(drawFrame);
				return;
			}
			lastFrame = time;

			context.clearRect(0, 0, width, height);
			context.fillStyle = "rgba(255, 255, 255, 0.055)";
			context.fillRect(0, 0, width, height);
			context.font = `${fontSize}px Arial, sans-serif`;
			context.textBaseline = "top";
			context.shadowColor = "rgba(0, 255, 65, 0.18)";
			context.shadowBlur = 5;

			columns.forEach((column, columnIndex) => {
				const rowCount = 2 + (columnIndex % 3);
				for (let row = 0; row < rowCount; row += 1) {
					const y = (column.y - row * fontSize * 1.55 + height) % height;
					const charIndex = Math.floor(time * 0.004 + column.phase + row + columnIndex) % symbols.length;
					const alpha = Math.max(0.12, column.alpha - row * 0.026);
					context.fillStyle = `rgba(0, 132, 42, ${alpha})`;
					context.fillText(symbols[charIndex], column.x, y);
				}
				column.y = (column.y + column.speed) % (height + fontSize * 8);
			});
			context.shadowBlur = 0;

			animationFrame = window.requestAnimationFrame(drawFrame);
		};

		resize();
		if (reducedMotion) {
			drawStatic();
		} else {
			animationFrame = window.requestAnimationFrame(drawFrame);
		}

		window.addEventListener("resize", () => {
			window.cancelAnimationFrame(animationFrame);
			resize();
			if (reducedMotion) {
				drawStatic();
			} else {
				animationFrame = window.requestAnimationFrame(drawFrame);
			}
		}, { passive: true });
	}

	const platformTitle = document.querySelector("[data-platform-matrix-title]");
	if (platformTitle instanceof HTMLElement && !reducedMotion) {
		const symbols = ["0", "1", "A", "F", "X", "/", "{", "}", "S", "Y", "C", "D", "E"];
		const phrase = "HACK THE FUTURE";
		let started = false;
		const cells = phrase.split("").map((character, index) => {
			const cell = document.createElement("span");
			cell.className = character === " " ? "matrix-title-cell matrix-title-cell--space" : "matrix-title-cell";
			cell.style.setProperty("--matrix-cell-delay", `${index * 34 + Math.random() * 80}ms`);

			if (character !== " ") {
				const glyph = document.createElement("span");
				glyph.className = "matrix-title-glyph";
				glyph.textContent = symbols[(index * 4) % symbols.length];
				cell.append(glyph);
			}

			platformTitle.append(cell);
			return { cell, character };
		});

		const startPlatformPrint = () => {
			if (started) return;
			started = true;
			window.setTimeout(() => {
				platformTitle.classList.add("is-matrix-title-printing");
				const glyphTimer = window.setInterval(() => {
					cells.forEach(({ cell }, index) => {
						const glyph = cell.querySelector(".matrix-title-glyph");
						if (glyph && !glyph.classList.contains("is-matrix-title-locked")) {
							glyph.textContent = symbols[(Math.floor(performance.now() * 0.018) + index * 3) % symbols.length];
						}
					});
				}, 70);

				cells.forEach(({ cell, character }, index) => {
					if (character === " ") return;
					window.setTimeout(() => {
						const glyph = cell.querySelector(".matrix-title-glyph");
						if (glyph) {
							glyph.textContent = character;
							glyph.classList.add("is-matrix-title-locked");
						}
					}, 880 + index * 34);
				});

				window.setTimeout(() => {
					window.clearInterval(glyphTimer);
					cells.forEach(({ cell, character }) => {
						if (character === " ") return;
						const glyph = cell.querySelector(".matrix-title-glyph");
						if (glyph) {
							glyph.textContent = character;
							glyph.classList.add("is-matrix-title-locked");
						}
					});
				}, 1450);
			}, 220);
		};

		const waitForBottomUpBoot = () => {
			if (!document.documentElement.classList.contains("is-bottom-up-booting")) {
				startPlatformPrint();
				return;
			}

			const observer = new MutationObserver(() => {
				if (!document.documentElement.classList.contains("is-bottom-up-booting")) {
					observer.disconnect();
					startPlatformPrint();
				}
			});

			observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
			window.setTimeout(() => {
				observer.disconnect();
				startPlatformPrint();
			}, 1600);
		};

		window.requestAnimationFrame(waitForBottomUpBoot);
	}

	if (platformTitle instanceof HTMLElement && reducedMotion) {
		platformTitle.textContent = "Hack The Future";
	}

</script>
