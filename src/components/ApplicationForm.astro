---
const themes = [
	"Future of Work",
	"Environment & Crisis Response",
	"Mental Health & Youth Wellbeing",
	"Local Products, Food & Future Business",
];

const applicationTypes = ["Applying alone", "Applying with a team"];
---

<form class="application-form grid gap-6" data-application-form>
	<div class="application-fields-grid grid gap-x-5 gap-y-5 md:grid-cols-2">
		<label class="application-field">
			<span>Name</span>
			<input name="name" type="text" required autocomplete="name" />
		</label>

		<label class="application-field">
			<span>Email</span>
			<input name="email" type="email" required autocomplete="email" />
		</label>

		<label class="application-field">
			<span>Age</span>
			<input name="age" type="number" required min="15" max="19" inputmode="numeric" />
		</label>

		<label class="application-field">
			<span>School</span>
			<input name="school" type="text" required autocomplete="organization" />
		</label>

		<label class="application-field md:col-span-2">
			<span>Why are you keen to join?</span>
			<textarea name="motivation" required minlength="140" rows="4"></textarea>
		</label>
	</div>

	<fieldset class="application-fieldset" data-theme-fieldset>
		<legend>Theme selection</legend>
		<div class="application-options mt-3 grid gap-2 sm:grid-cols-2">
			{themes.map((theme) => (
				<label class="application-choice">
					<input name="themes" type="checkbox" value={theme} data-theme-input />
					<span>{theme}</span>
				</label>
			))}
		</div>
	</fieldset>

	<fieldset class="application-fieldset">
		<legend>Application type</legend>
		<div class="application-options mt-3 grid gap-2 sm:grid-cols-2">
			{applicationTypes.map((type) => (
				<label class="application-radio">
					<input name="application_type" type="radio" value={type} required />
					<span>{type}</span>
				</label>
			))}
		</div>
	</fieldset>

	<label class="application-field application-team-name" data-team-name-field hidden>
		<span>Team name</span>
		<input name="team_name" type="text" autocomplete="organization" data-team-name-input />
	</label>

	<div class="pt-1.5">
		<button type="submit" class="application-submit inline-flex min-h-12 items-center justify-center rounded-[9px] px-6 text-sm font-semibold uppercase tracking-[0.12em] text-white transition duration-200">
			Register Interest
		</button>
	</div>

	<p class="application-status text-sm leading-6 text-[var(--color-muted)]" data-application-status aria-live="polite"></p>
</form>

<script>
	function handleHackTheFutureApplicationSubmit(event) {
		event.preventDefault();

		const form = event.currentTarget;
		if (!(form instanceof HTMLFormElement)) {
			return;
		}

		const formData = new FormData(form);
		const payload = {
			...Object.fromEntries(formData.entries()),
			themes: formData.getAll("themes"),
		};

		// Placeholder for future Google Sheets integration.
		console.info("Hack The Future application interest:", payload);

		const status = form.querySelector("[data-application-status]");
		if (status instanceof HTMLElement) {
			status.textContent = "Thanks. Your interest has been noted locally for now.";
		}
	}

	function syncTeamNameField(form) {
		const selectedType = form.querySelector('input[name="application_type"]:checked');
		const teamNameField = form.querySelector("[data-team-name-field]");
		const teamNameInput = form.querySelector("[data-team-name-input]");

		if (!(selectedType instanceof HTMLInputElement) || !(teamNameField instanceof HTMLElement) || !(teamNameInput instanceof HTMLInputElement)) {
			return;
		}

		const shouldShowTeamName = selectedType.value === "Applying with a team";
		teamNameField.hidden = !shouldShowTeamName;
		teamNameInput.required = shouldShowTeamName;

		if (!shouldShowTeamName) {
			teamNameInput.value = "";
		}
	}

	function syncThemeSelectionValidity(form) {
		const themeInputs = Array.from(form.querySelectorAll("[data-theme-input]"));
		const firstThemeInput = themeInputs[0];

		if (!(firstThemeInput instanceof HTMLInputElement)) {
			return;
		}

		const hasThemeSelection = themeInputs.some((input) => input instanceof HTMLInputElement && input.checked);
		firstThemeInput.setCustomValidity(hasThemeSelection ? "" : "Please select at least one theme.");
	}

	document.querySelectorAll("[data-application-form]").forEach((form) => {
		form.addEventListener("submit", handleHackTheFutureApplicationSubmit);

		if (form instanceof HTMLFormElement) {
			form.addEventListener("change", (event) => {
				const target = event.target;

				if (target instanceof HTMLInputElement && target.name === "application_type") {
					syncTeamNameField(form);
				}

				if (target instanceof HTMLInputElement && target.name === "themes") {
					syncThemeSelectionValidity(form);
				}
			});

			syncTeamNameField(form);
			syncThemeSelectionValidity(form);
		}
	});
</script>

<style>
	.application-form {
		position: relative;
		padding-top: 0.1rem;
	}

	.application-form::before {
		content: "";
		display: block;
		width: 100%;
		height: 1px;
		margin-bottom: 1.35rem;
		background: linear-gradient(90deg, rgba(10, 10, 10, 0.2), rgba(124, 58, 237, 0.18), transparent);
	}

	.application-field,
	.application-fieldset {
		display: grid;
		gap: 0.55rem;
	}

	.application-field span,
	.application-fieldset legend {
		color: color-mix(in srgb, var(--color-purple) 62%, var(--color-ink));
		font-size: 0.68rem;
		font-weight: 650;
		letter-spacing: 0.18em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.application-field input,
	.application-field textarea,
	.application-field select {
		width: 100%;
		border: 1px solid rgba(10, 10, 10, 0.13);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.74);
		color: var(--color-ink);
		font: inherit;
		line-height: 1.5;
		padding: 0.86rem 0.95rem;
		outline: none;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease;
	}

	.application-field textarea {
		resize: vertical;
		min-height: 7rem;
	}

	.application-field input:focus,
	.application-field textarea:focus,
	.application-field select:focus {
		border-color: rgba(124, 58, 237, 0.62);
		background: rgba(255, 255, 255, 0.98);
		box-shadow:
			0 0 0 3px rgba(124, 58, 237, 0.09),
			0 14px 34px rgba(10, 10, 10, 0.07);
	}

	.application-fieldset {
		margin: 0;
		border: 1px solid rgba(10, 10, 10, 0.1);
		border-width: 1px 0 0;
		padding: 1.1rem 0 0;
	}

	.application-radio,
	.application-choice {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.7rem;
		min-height: 3.05rem;
		border: 1px solid rgba(10, 10, 10, 0.11);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.5);
		padding: 0.78rem 0.86rem;
		color: var(--color-ink);
		font-size: 0.94rem;
		font-weight: 550;
		line-height: 1.45;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.68);
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.application-radio:hover,
	.application-choice:hover {
		border-color: rgba(124, 58, 237, 0.42);
		background: rgba(255, 255, 255, 0.84);
		box-shadow: 0 10px 26px rgba(10, 10, 10, 0.045);
		transform: translateY(-1px);
	}

	.application-radio input,
	.application-choice input {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
		accent-color: var(--color-purple);
	}

	.application-radio:has(input:checked),
	.application-choice:has(input:checked) {
		border-color: rgba(124, 58, 237, 0.48);
		background:
			linear-gradient(135deg, rgba(124, 58, 237, 0.075), rgba(255, 255, 255, 0.82)),
			rgba(255, 255, 255, 0.9);
		box-shadow:
			inset 0 0 0 1px rgba(124, 58, 237, 0.08),
			0 12px 30px rgba(124, 58, 237, 0.07);
	}

	.application-submit {
		background: var(--gradient-button);
		border: 1px solid rgba(10, 10, 10, 0.92);
		box-shadow: 0 14px 36px rgba(10, 10, 10, 0.15);
	}

	.application-submit:hover {
		transform: translateY(-2px);
		border-color: var(--color-accent);
		box-shadow: 0 16px 42px rgba(10, 10, 10, 0.18), 0 0 20px rgba(124, 58, 237, 0.16);
	}
</style>
