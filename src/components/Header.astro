---
import { getLang, langPath, siteCopy, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const t = siteCopy[lang];
const currentPath = Astro.url.pathname.replace(/^\/(en|bg)/, "") || "/";
const pageLinkLabels = {
	en: {
		introduction: "Introduction",
		challenges: "Challenges",
		schedule: "Schedule",
		whoCanJoin: "Who can join",
		apply: "Apply",
		about: "About",
	},
	bg: {
		introduction: "Introduction",
		challenges: "Challenges",
		schedule: "Schedule",
		whoCanJoin: "Who can join",
		apply: "Apply",
		about: "About",
	},
}[lang];
const pageLinks = [
	{ label: pageLinkLabels.introduction, href: `${langPath(lang)}#introduction` },
	{ label: pageLinkLabels.challenges, href: `${langPath(lang)}#challenges` },
	{ label: pageLinkLabels.schedule, href: `${langPath(lang)}#schedule` },
	{ label: pageLinkLabels.whoCanJoin, href: `${langPath(lang)}#who-can-join` },
	{ label: pageLinkLabels.apply, href: `${langPath(lang)}#apply` },
	{ label: pageLinkLabels.about, href: `${langPath(lang)}#about` },
];
---

<header class="site-header sticky top-0 z-40 border-b border-[rgba(10,10,10,0.1)] bg-[rgba(255,255,255,0.92)] px-6 py-3.5 shadow-[0_1px_0_rgba(255,255,255,0.75)_inset] backdrop-blur-md sm:px-10 lg:px-16">
	<div class="site-header-inner mx-auto grid max-w-7xl grid-cols-[1fr_auto] items-center gap-x-8 gap-y-4 lg:grid-cols-[1fr_auto_auto]">
		<a
			href={langPath(lang)}
			class="site-brand flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.26em] text-[var(--color-ink)] no-underline"
			aria-label={t.nav.home}
		>
			<img
				src="/catalizator-logo.png"
				alt=""
				class="site-brand-mark h-8 w-8 object-contain mix-blend-multiply"
				loading="eager"
				decoding="async"
			/>
			Hack The Future
		</a>

		<nav class="site-nav order-3 col-span-2 flex flex-wrap items-center gap-x-5 gap-y-3 text-[0.82rem] text-[var(--color-muted)] lg:order-none lg:col-span-1" aria-label={t.nav.primary}>
			<div class="site-nav-page-links flex flex-wrap items-center gap-x-5 gap-y-3 text-[0.74rem] uppercase tracking-[0.12em] text-[var(--color-muted)]/78">
				{pageLinks.map((link) => (
					<a class="site-nav-link" href={link.href}>{link.label}</a>
				))}
			</div>
		</nav>

		<div class="site-language flex items-center gap-2 text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-muted)]" aria-label={t.nav.language}>
			<a class={`${lang === "en" ? "text-[var(--color-ink)]" : "hover:text-[var(--color-purple)]"} no-underline`} href={langPath("en", currentPath)} aria-current={lang === "en" ? "true" : undefined}>EN</a>
			<span class="h-3 w-px bg-[var(--color-line)]" aria-hidden="true"></span>
			<a class={`${lang === "bg" ? "text-[var(--color-ink)]" : "hover:text-[var(--color-purple)]"} no-underline`} href={langPath("bg", currentPath)} aria-current={lang === "bg" ? "true" : undefined}>BG</a>
		</div>
	</div>
</header>
