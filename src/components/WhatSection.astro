---
import Section from "./Section.astro";
import { getLang, siteCopy, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const t = siteCopy[lang].what;
---

<Section
	eyebrow={t.eyebrow}
	title={t.title}
	intro={t.intro}
>
	<div class="grid gap-4 md:grid-cols-2">
		{t.principles.map((item, index) => (
			<article class="quiet-card min-h-52 rounded-[1.25rem] p-6">
				<div class="flex items-center justify-between gap-4">
					<h3 class="text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-purple)]">
						{item.title}
					</h3>
					<span class="text-xs font-semibold text-[var(--color-muted)]/55">0{index + 1}</span>
				</div>
				<p class="mt-8 max-w-2xl text-base leading-8 text-[var(--color-muted)]">
					{item.body}
				</p>
			</article>
		))}
	</div>
</Section>
