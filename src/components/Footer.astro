---
import { getLang, langPath, siteCopy, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const t = siteCopy[lang];
const currentPath = Astro.url.pathname.replace(/^\/(en|bg)/, "") || "/";
const footerCopy = {
	en: {
		tagline: ["You bring the energy. We bring the challenge.", "Together, we hack the future."],
		contactLabel: "Contact",
		credit: "Website by IT-S",
		accessibility: "This website is developed with a dyslexia-friendly font.",
		initiativePartnersLabel: "Initiative partners",
	},
	bg: {
		tagline: ["Ти носиш енергията. Ние даваме предизвикателството.", "Заедно създаваме бъдещето."],
		contactLabel: "Контакт",
		credit: "Уебсайт от IT-S",
		accessibility: "Този уебсайт използва шрифт, съобразен с нуждите на хора с дислексия.",
		initiativePartnersLabel: "Партньори на инициативата",
	},
}[lang];

const partners = [
	{
		name: "Municipality of Shumen",
		localizedName: t.about.partners[0].name,
		logo: "https://www.shumen.bg/assets/images/logo.svg",
		href: "https://www.shumen.bg/bg/",
		className: "partner-logo--shumen",
	},
	{
		name: "Sofia Tech Park BIC",
		localizedName: t.about.partners[1].name,
		logo: "https://sofiatech.bg/wp-content/uploads/2023/10/logo-stp.svg",
		href: "https://sofiatech.bg/",
		className: "partner-logo--sofia-tech",
	},
	{
		name: "Shumen IT",
		localizedName: t.about.partners[2].name,
		logo: "https://shumen-it.com/wp-content/uploads/2019/08/logo-sit-2.png",
		href: "https://shumen-it.com/",
		className: "partner-logo--shumen-it",
	},
];

const initiativePartners = [
	{ name: "Alcomet", logo: "/initiative-partners/alcomet.jpeg", size: "wide" },
	{ name: "ITS", logo: "/initiative-partners/its.png", size: "badge" },
	{ name: "Love 2 Design", logo: "/initiative-partners/love-2-design.jpg", size: "square" },
	{ name: "Zarra Coffee", logo: "/initiative-partners/zarra-coffee.webp", size: "compact" },
	{ name: "Avtomagistrali - Cherno More", logo: "/initiative-partners/avtomagistrali-cherno-more.png", size: "tall" },
	{ name: "BulMag", logo: "/initiative-partners/bulmag.png", size: "wide" },
	{ name: "Contessa", logo: "/initiative-partners/contessa.png", size: "wide" },
	{ name: "Enola", logo: "/initiative-partners/enola.jpg", size: "wide" },
	{ name: "Vivacom", logo: "/initiative-partners/vivacom.png", size: "wide" },
	{ name: "BGRobots", logo: "/initiative-partners/bg-robots-tight.png", size: "wide" },
	{ name: "National Military University Vasil Levski", logo: "/initiative-partners/nvu-vasil-levski.png", size: "wide" },
	{ name: "Sark Bulgaria", logo: "/initiative-partners/sark-bulgaria.jpg", size: "wide" },
	{ name: "Telepol", logo: "/initiative-partners/telepol.png", size: "tall" },
	{ name: "TESY", logo: "/initiative-partners/tesy-logo.png", size: "wide" },
	{ name: "TV Shumen", logo: "/initiative-partners/tv-shumen.webp", size: "compact" },
	{ name: "Kinse Media", logo: "/initiative-partners/kinse-media.png", size: "tall" },
];

const year = new Date().getFullYear();
---

<footer id="contact" class="gradient-rule civic-grid scroll-mt-28 border-t border-[rgba(17,17,17,0.1)] bg-[var(--color-paper)] px-6 py-10 text-[var(--color-muted)] sm:px-10 sm:py-12 lg:px-16">
	<div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[minmax(0,1fr)_auto]">
		<div>
			<p class="footer-tagline max-w-5xl text-xl leading-tight text-[var(--color-ink)]/88 sm:text-2xl lg:text-3xl">
				{footerCopy.tagline.map((line) => (
					<span class="block">{line}</span>
				))}
			</p>
		</div>

		<div class="flex flex-col gap-6 text-[0.82rem] md:items-end">
			<nav class="flex flex-wrap items-center gap-x-6 gap-y-3" aria-label={t.nav.footer}>
				{t.footer.links.map((link) => (
					<a class="no-underline hover:text-[var(--color-purple)]" href={link.href.startsWith("http") ? link.href : langPath(lang, link.href)}>{link.label}</a>
				))}
				<a class="footer-contact-link no-underline" href="mailto:social@catalizator.org">
					<svg viewBox="0 0 24 24" class="footer-contact-icon" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="3" y="5" width="18" height="14" rx="2"></rect>
						<path d="m3.5 7 8.5 6 8.5-6"></path>
					</svg>
					<span class="footer-contact-label">{footerCopy.contactLabel}:</span>
					<span class="footer-contact-email">social@catalizator.org</span>
				</a>
			</nav>

			<div class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.18em]" aria-label={t.nav.language}>
				<a class={`${lang === "en" ? "text-[var(--color-ink)]" : "hover:text-[var(--color-purple)]"} no-underline`} href={langPath("en", currentPath)} aria-current={lang === "en" ? "true" : undefined} data-language-option="en">EN</a>
				<span class="h-3 w-px bg-[var(--color-line)]" aria-hidden="true"></span>
				<a class={`${lang === "bg" ? "text-[var(--color-ink)]" : "hover:text-[var(--color-purple)]"} no-underline`} href={langPath("bg", currentPath)} aria-current={lang === "bg" ? "true" : undefined} data-language-option="bg">BG</a>
			</div>

			<p class="text-xs uppercase tracking-[0.18em]">
				&copy; {year} Hack The Future
			</p>

			<a
				class="footer-credit text-[0.68rem] no-underline"
				href="https://www.it-s.org"
				target="_blank"
				rel="noopener noreferrer"
			>
				{footerCopy.credit}
			</a>

			<a
				class="footer-accessibility-credit no-underline"
				href="https://adysfont.com/"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img src="/adys-logo.svg" alt="" loading="lazy" decoding="async" />
				<span>{footerCopy.accessibility}</span>
			</a>
		</div>

		<div class="footer-partners md:col-span-2" aria-labelledby="founding-partners-title">
			<p id="founding-partners-title" class="text-[0.66rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-muted)]/64">
				{t.footer.founders}
			</p>

			<ul class="main-partner-logos mt-6" aria-label={t.footer.partnerLabel}>
				{partners.map((partner) => (
					<li class="flex h-10 items-center">
						<a class="partner-logo-link" href={partner.href} target="_blank" rel="noopener noreferrer" aria-label={`${partner.localizedName} ${t.footer.website}`}>
							<img
								class={`partner-logo ${partner.className}`}
								src={partner.logo}
								alt={partner.localizedName}
								loading="lazy"
								decoding="async"
							/>
						</a>
					</li>
				))}
			</ul>

			<ul class="initiative-partner-logos mt-8" aria-label={footerCopy.initiativePartnersLabel}>
				{initiativePartners.map((partner) => (
					<li class="initiative-partner-logo-item">
						<img
							class={`initiative-partner-logo initiative-partner-logo--${partner.size}`}
							src={partner.logo}
							alt={partner.name}
							loading="lazy"
							decoding="async"
						/>
					</li>
				))}
			</ul>
		</div>
	</div>
</footer>
