---
const days = [
	{
		number: "03",
		label: "June 27",
		title: "Award ceremony.",
		body: "The strongest teams are recognized in front of the city.",
		weight: "compact",
	},
	{
		number: "02",
		label: "June 27",
		title: "Build and present.",
		body: "Your team turns your idea into something real you can show. Mentors stay in the room. By the end of the day, every team presents to the jury.",
		weight: "medium",
	},
	{
		number: "01",
		label: "June 26",
		title: "Form, choose, start.",
		body: "Teams form in the morning. You meet your team, pick your theme, and start working. Mentors are in the room throughout the day to push back on weak ideas, sharpen the strong ones, and connect you to information you don't yet have. Workshops in the afternoon on how to build a pitch.",
		weight: "dominant",
	},
];
---

<section id="schedule" class="motion-section civic-grid px-4 py-[4.25rem] sm:px-6 sm:py-[5.25rem] lg:px-8 lg:py-[6.5rem]">
	<div class="mx-auto max-w-7xl">
		<div class="editorial-timeline" data-schedule-timeline>
			<div class="timeline-rail" aria-hidden="true">
				<span></span>
			</div>

			<ol class="timeline-content">
				{days.map((day, index) => (
					<li
						class={`timeline-entry timeline-entry--${day.weight}`}
						data-schedule-step={day.number}
						style={`--timeline-index: ${index}`}
					>
						<div class="timeline-marker" aria-hidden="true"></div>
						<p class="timeline-day-label">{day.label}</p>
						<div class="timeline-entry-grid">
							<p class="timeline-day-number" data-day-number={day.number}>{day.number}</p>
							<div>
								<h3 class="timeline-title">{day.title}</h3>
								<p class="timeline-body">{day.body}</p>
							</div>
						</div>
					</li>
				))}
			</ol>
		</div>

		<p class="section-kicker schedule-bottom-kicker">
			SCHEDULE
		</p>
	</div>
</section>

<style>
	.schedule-bottom-kicker {
		margin-top: 4.75rem;
	}

	.editorial-timeline {
		--timeline-number-column: clamp(12rem, 16vw, 16rem);
		position: relative;
		display: grid;
		grid-template-columns: minmax(3rem, 0.12fr) minmax(0, 1fr);
		gap: clamp(1.25rem, 3vw, 3rem);
	}

	.timeline-rail {
		position: relative;
		min-height: 100%;
	}

	.timeline-rail::before {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		left: clamp(1.25rem, 3vw, 3rem);
		width: 1px;
		background: rgba(10, 10, 10, 0.14);
	}

	.timeline-rail span {
		position: absolute;
		top: 0;
		left: clamp(1.25rem, 3vw, 3rem);
		width: 1px;
		height: 100%;
		background: linear-gradient(180deg, rgba(10, 10, 10, 0.34), rgba(124, 58, 237, 0.3), rgba(10, 10, 10, 0.18));
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 1500ms var(--ease-premium);
	}

	.motion-ready .timeline-rail span {
		transform: scaleY(1);
	}

	.timeline-content {
		display: grid;
		gap: clamp(4.5rem, 8vw, 8rem);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.timeline-entry {
		position: relative;
		opacity: 0;
		transform: translate3d(0, 1.35rem, 0);
		transition:
			opacity 720ms var(--ease-premium),
			transform 720ms var(--ease-premium);
		transition-delay: calc(var(--timeline-index) * 120ms);
	}

	.motion-ready:not(.schedule-sequence-ready) .timeline-entry {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	#schedule.schedule-sequence-ready .timeline-entry {
		opacity: 0;
		transform: translate3d(0, 2rem, 0);
		transition:
			opacity 1280ms cubic-bezier(0.16, 1, 0.3, 1),
			transform 1280ms cubic-bezier(0.16, 1, 0.3, 1);
		transition-delay: 0ms;
	}

	#schedule.schedule-sequence-ready .timeline-entry.is-step-visible {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	#schedule.schedule-sequence-ready .timeline-entry.is-step-visible .timeline-marker {
		border-color: rgba(196, 181, 253, 0.52);
		box-shadow:
			0 0 0 0.3rem rgba(255, 255, 255, 0.62),
			0 0 1.1rem rgba(167, 139, 250, 0.18);
	}

	.timeline-marker {
		position: absolute;
		top: 0.05rem;
		left: calc(clamp(-5rem, -5vw, -2rem) - 0.44rem);
		width: 0.88rem;
		height: 0.88rem;
		border: 1px solid rgba(196, 181, 253, 0.5);
		border-radius: 999px;
		background:
			radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.5) 0 0.16rem, transparent 0.17rem),
			radial-gradient(circle at 50% 50%, rgba(196, 181, 253, 0.14), transparent 72%),
			var(--color-paper);
		box-shadow:
			0 0 0 0.34rem rgba(255, 255, 255, 0.72),
			0 0 1.25rem rgba(167, 139, 250, 0.2);
	}

	.timeline-marker::after {
		content: none;
		position: absolute;
		inset: -0.28rem;
		border-radius: inherit;
		border: 1px solid rgba(167, 139, 250, 0.08);
		background: transparent;
	}

	.timeline-day-label {
		margin: 0 0 1.5rem;
		width: var(--timeline-number-column);
		color: var(--color-purple);
		font-size: 0.86rem;
		font-weight: 850;
		letter-spacing: 0.18em;
		line-height: 1.2;
		text-align: center;
		text-transform: uppercase;
	}

	.timeline-entry-grid {
		display: grid;
		grid-template-columns: var(--timeline-number-column) minmax(0, 1fr);
		gap: clamp(3rem, 5vw, 4.5rem);
		align-items: start;
	}

	.timeline-day-number {
		margin: 0;
		color: color-mix(in srgb, var(--color-purple) 16%, transparent);
		font-size: clamp(4.5rem, 12vw, 10rem);
		font-weight: 600;
		letter-spacing: -0.06em;
		line-height: 0.78;
		text-align: center;
		font-variant-numeric: tabular-nums;
	}

	.timeline-title {
		margin: 0;
		max-width: 16ch;
		color: var(--color-ink);
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.02;
		text-wrap: balance;
	}

	.timeline-body {
		margin: 1.5rem 0 0;
		max-width: 46rem;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.85;
		text-wrap: pretty;
	}

	.timeline-entry--dominant .timeline-title {
		font-size: clamp(2.5rem, 5.3vw, 5.4rem);
	}

	.timeline-entry--dominant .timeline-body {
		max-width: 54rem;
		font-size: 1.06rem;
	}

	.timeline-entry--medium {
		margin-left: clamp(0rem, 5vw, 4rem);
	}

	.timeline-entry--medium .timeline-title {
		font-size: clamp(2rem, 4vw, 4.1rem);
	}

	.timeline-entry--compact {
		margin-left: clamp(0rem, 10vw, 8rem);
		padding-bottom: 1rem;
	}

	.timeline-entry--compact .timeline-entry-grid {
		gap: clamp(3rem, 5vw, 4.5rem);
	}

	.timeline-entry--compact .timeline-day-number {
		color: color-mix(in srgb, var(--color-gold) 28%, transparent);
	}

	.timeline-entry--compact .timeline-title {
		color: var(--color-purple);
		font-size: clamp(1.75rem, 3vw, 3.1rem);
	}

	.timeline-entry:hover .timeline-marker {
		border-color: rgba(124, 58, 237, 0.6);
		box-shadow:
			0 0 0 0.65rem rgba(255, 255, 255, 0.96),
			0 20px 48px rgba(10, 10, 10, 0.16),
			0 0 20px rgba(124, 58, 237, 0.12);
		transform: translate3d(0, -0.08rem, 0) scale(1.04);
		transition:
			border-color 240ms ease,
			box-shadow 240ms ease,
			transform 240ms ease;
	}

	@media (max-width: 767px) {
		.editorial-timeline {
			grid-template-columns: 1.5rem minmax(0, 1fr);
			gap: 1.5rem;
		}

		.timeline-rail::before,
		.timeline-rail span {
			left: 0.68rem;
		}

		.timeline-content {
			gap: 4rem;
		}

		.timeline-day-label {
			width: auto;
			text-align: left;
		}

		.timeline-marker {
			left: -2.43rem;
		}

		.timeline-entry,
		.timeline-entry--medium,
		.timeline-entry--compact {
			margin-left: 0;
		}

		.timeline-entry-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.timeline-day-number {
			font-size: clamp(4.2rem, 24vw, 7rem);
		}
	}

</style>

<script>
	const scheduleSection = document.querySelector<HTMLElement>("#schedule");
	const scheduleEntries = Array.from(document.querySelectorAll<HTMLElement>("#schedule [data-schedule-step]"));
	const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const isBottomUpSchedule = document.body.dataset.scrollFlow === "bottom-up";

	if (scheduleSection && scheduleEntries.length && !reducedMotion) {
		const revealOrder = isBottomUpSchedule ? [...scheduleEntries].reverse() : [...scheduleEntries];
		let played = false;
		let ticking = false;
		let lastScrollY = window.scrollY;
		let hasMovedTowardSchedule = !isBottomUpSchedule || Boolean(window.location.hash);
		let scheduleObserver: IntersectionObserver | undefined;

		scheduleSection.classList.add("schedule-sequence-ready");

		const reveal = () => {
			if (played) return;
			played = true;
			scheduleSection.classList.add("schedule-sequence-played");
			revealOrder.forEach((entry, index) => {
				window.setTimeout(() => {
					entry.classList.add("is-step-visible");
				}, index * 920);
			});
			window.removeEventListener("scroll", requestCheck);
			window.removeEventListener("resize", requestCheck);
			window.removeEventListener("load", requestCheck);
			scheduleObserver?.disconnect();
		};

		const check = () => {
			ticking = false;
			if (played) return;

			const currentScrollY = window.scrollY;
			if (isBottomUpSchedule ? currentScrollY < lastScrollY - 2 : currentScrollY > lastScrollY + 2) {
				hasMovedTowardSchedule = true;
			}
			lastScrollY = currentScrollY;

			const rect = scheduleSection.getBoundingClientRect();
			const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
			const hasReachedSchedule = isBottomUpSchedule
				? rect.top < viewportHeight * 0.76 && rect.bottom > viewportHeight * 0.48
				: rect.top < viewportHeight * 0.72 && rect.bottom > viewportHeight * 0.2;

			if (hasMovedTowardSchedule && hasReachedSchedule) {
				reveal();
			}
		};

		function requestCheck() {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(check);
		}

		const startScheduleSequence = () => {
			if (played) return;

			if (!isBottomUpSchedule && "IntersectionObserver" in window) {
				scheduleObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								reveal();
							}
						});
					},
					{ threshold: 0.24, rootMargin: "0px 0px -18% 0px" }
				);
				scheduleObserver.observe(scheduleSection);
			}

			window.addEventListener("scroll", requestCheck, { passive: true });
			window.addEventListener("resize", requestCheck);
			window.addEventListener("load", requestCheck, { once: true });
			requestCheck();
			window.setTimeout(requestCheck, 160);
			window.setTimeout(requestCheck, 420);
		};

		const waitForBottomUpBoot = () => {
			if (!isBottomUpSchedule || !document.documentElement.classList.contains("is-bottom-up-booting")) {
				startScheduleSequence();
				return;
			}

			window.requestAnimationFrame(waitForBottomUpBoot);
		};

		waitForBottomUpBoot();
	} else {
		scheduleEntries.forEach((entry) => entry.classList.add("is-step-visible"));
	}
</script>
