---
import { getLang, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const copy = {
	en: {
		title: "The future is changing faster than the systems built around it.",
		body: "The people who will live longest with today's decisions usually have the smallest voice in making them.",
		alt: "Young people collaborating with technology in a city setting",
		location: "SHUMEN // BULGARIA",
		status: "FUTURE READINESS ACTIVE",
	},
	bg: {
		title: "Бъдещето се променя по-бързо от системите, създадени да го посрещнат.",
		body: "А хората, които ще живеят най-дълго с последствията от днешните решения, често имат най-малък глас при вземането им.",
		alt: "Млади хора работят с технологии в градска среда",
		location: "ШУМЕН // БЪЛГАРИЯ",
		status: "ГОТОВНОСТ ЗА БЪДЕЩЕТО",
	},
}[lang];
---

<section id="why" class="motion-section cinematic-dark px-4 py-20 text-[var(--color-paper)] sm:px-6 sm:py-24 lg:px-8 lg:py-32" data-why-lang={lang}>
	<div class="relative z-10 mx-auto grid max-w-7xl gap-5 lg:grid-cols-[0.8fr_1.2fr]">
		<div class="why-brief-card premium-hover flex min-h-[28rem] flex-col justify-center rounded-[9px] border border-white/10 bg-white/[0.045] p-6 sm:p-8 lg:justify-start">
			<div class="why-brief-copy">
				<h2 class={`why-title ${lang === "bg" ? "why-title--bg" : ""}`}>
					{lang === "en" ? <>The <span class="why-accent">future</span> is changing faster than the systems built around it.</> : <><span class="why-accent">Бъдещето</span> се променя по-бързо от системите, създадени да го посрещнат.</>}
				</h2>
				<p class="why-body">
					{copy.body}
				</p>
			</div>
		</div>

		<div
			class="why-image-card media-placeholder cinematic-frame image-card plain-photo-frame min-h-[28rem] rounded-[9px] lg:min-h-[36rem]"
		>
			<img
				class="media-photo"
				src="/hack-future-shumen-team-plaza.png"
				alt={copy.alt}
				loading="lazy"
				decoding="async"
			/>
			<div class="why-photo-overlay" aria-hidden="true">
				<span class="why-photo-label why-photo-location">{copy.location}</span>
				<span class="why-photo-label why-photo-status">{copy.status}</span>
			</div>
		</div>
	</div>
</section>

<style>
	.why-brief-card,
	.why-image-card {
		position: relative;
		box-shadow: 0 30px 100px rgba(0, 0, 0, 0.28), 0 0 54px rgba(124, 58, 237, 0.13);
	}

	.why-brief-card::before,
	.why-image-card::before {
		position: absolute;
		inset: -1px;
		z-index: -1;
		border-radius: inherit;
		background: radial-gradient(circle at 52% 18%, rgba(167, 139, 250, 0.16), transparent 42%);
		content: "";
		opacity: 0.72;
	}

	.why-system-label {
		color: rgba(196, 181, 253, 0.68);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.why-brief-copy {
		padding-block: clamp(1.25rem, 5vw, 4.5rem);
	}

	.why-title {
		max-width: 42rem;
		color: var(--color-paper);
		font-size: clamp(2rem, 3.4vw, 3rem);
		font-weight: 600;
		letter-spacing: -0.035em;
		line-height: 1.08;
		text-wrap: balance;
	}

	.why-title--bg {
		font-size: clamp(1.7rem, 2.65vw, 2.42rem);
		letter-spacing: -0.018em;
		line-height: 1.16;
	}

	.why-body {
		max-width: 36rem;
		margin-top: 1.5rem;
		color: rgba(255, 255, 255, 0.66);
		font-size: 1rem;
		line-height: 1.64;
	}

	[data-why-lang="bg"] .why-body {
		max-width: 34rem;
		font-size: 0.9rem;
		line-height: 1.58;
	}

	.why-accent {
		color: #a78bfa;
	}

	.why-image-card {
		overflow: hidden;
	}

	.why-photo-overlay {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.why-photo-overlay::before {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 5.5rem 5.5rem;
		content: "";
		opacity: 0.08;
	}

	.why-photo-label {
		position: absolute;
		border: 1px solid rgba(196, 181, 253, 0.24);
		background: rgba(4, 5, 10, 0.28);
		padding: 0.3rem 0.42rem;
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.5rem;
		font-weight: 750;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		backdrop-filter: blur(10px);
	}

	.why-photo-location {
		left: 0.95rem;
		bottom: 0.95rem;
	}

	.why-photo-status {
		right: 0.95rem;
		top: 0.95rem;
		color: rgba(251, 146, 60, 0.72);
	}

</style>
