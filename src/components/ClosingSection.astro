---
import ApplicationForm from "./ApplicationForm.astro";

const checklist = [
	{
		title: "Students aged 15–19",
		icon: "M12 3v18M5 8h14M7 16h10",
		size: "tall",
	},
	{
		title: "From Shumen or anywhere in Bulgaria",
		icon: "M12 21s7-5.1 7-11a7 7 0 0 0-14 0c0 5.9 7 11 7 11Z M12 10.5h.01",
		size: "short",
	},
	{
		title: "Apply alone or with a team",
		icon: "M8 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM16 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3 21a5 5 0 0 1 10 0M13.5 20.5a4.5 4.5 0 0 1 7.5 0",
		size: "short",
	},
	{
		title: "Schools can nominate students",
		icon: "M4 10l8-5 8 5-8 5-8-5ZM6 12v5c1.5 1.4 3.5 2 6 2s4.5-.6 6-2v-5",
		size: "tall",
	},
	{
		title: "No experience required",
		icon: "M20 6 9 17l-5-5",
		size: "wide",
	},
];

const checklistColumns = [checklist.slice(0, 3), checklist.slice(3)];

const partners = [
	{
		name: "Municipality of Shumen",
		subtitle: "Host institution",
	},
	{
		name: "Sofia Tech Park",
		subtitle: "Innovation partner",
	},
	{
		name: "Shumen Institute of Technology",
		subtitle: "Academic partner",
	},
	{
		name: "Visoko Darvo",
		subtitle: "Strategic partner",
	},
];

---

<div class="closing-bottom-up-stack">
<section id="who-can-join" class="closing-bottom-up-item closing-bottom-up-item--who motion-section civic-grid px-4 py-12 sm:px-6 sm:py-14 lg:px-8 lg:py-16">
	<div class="relative mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-purple)]">
				PARTICIPATION
			</p>
			<h2 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
				Who can join
			</h2>
			<p class="mt-6 max-w-md text-base leading-8 text-[var(--color-muted)]">
				Anyone with curiosity, ideas, and the desire to build something real.
			</p>
		</div>

		<div class="participation-list grid gap-x-12 gap-y-3 sm:grid-cols-2">
			{checklistColumns.map((column, columnIndex) => (
				<div class={`participation-list-column ${columnIndex === 1 ? "sm:pt-[4.35rem]" : ""}`}>
					{column.map((item) => (
						<div class="participation-list-item group flex items-center gap-4 border-t border-[var(--color-line)] py-4">
							<span class="participation-icon grid h-9 w-9 shrink-0 place-items-center rounded-full bg-[rgba(10,10,10,0.06)] text-[var(--color-ink)] transition duration-300 group-hover:-translate-y-0.5 group-hover:bg-[rgba(124,58,237,0.12)] group-hover:text-[var(--color-ink)] group-hover:shadow-[0_0_20px_rgba(124,58,237,0.12)]" aria-hidden="true">
								<svg viewBox="0 0 24 24" class="h-[1.125rem] w-[1.125rem]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d={item.icon} />
								</svg>
							</span>
							<h3 class="text-base font-semibold leading-7 tracking-[-0.015em] text-[var(--color-ink)]">
								{item.title}
							</h3>
						</div>
					))}
				</div>
			))}
		</div>
	</div>
</section>

<div class="closing-bottom-up-item closing-bottom-up-item--brand brand-divider px-4 py-2 sm:px-6 lg:px-8" aria-hidden="true">
	<div class="brand-divider-mask mx-auto flex max-w-7xl items-center overflow-hidden py-3">
		<div class="brand-divider-track flex items-center gap-5 text-[0.66rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-paper)]/76">
			{Array.from({ length: 2 }).map(() => (
				<div class="brand-divider-sequence flex items-center gap-5 pr-5">
					<span>CATALIZATOR</span>
					<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
						<circle cx="64" cy="64" r="42" />
						<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
						<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
						<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
					</svg>
					<span>HACK THE FUTURE</span>
					<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
						<circle cx="64" cy="64" r="42" />
						<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
						<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
						<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
					</svg>
					<span>SHUMEN</span>
					<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
						<circle cx="64" cy="64" r="42" />
						<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
						<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
						<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
					</svg>
					<span>FUTURE READINESS CHALLENGE</span>
					<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
						<circle cx="64" cy="64" r="42" />
						<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
						<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
						<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
					</svg>
					<span>YOUNG PEOPLE</span>
					<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
						<circle cx="64" cy="64" r="42" />
						<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
						<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
						<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
					</svg>
				</div>
			))}
		</div>
	</div>
</div>

<section id="apply" class="closing-bottom-up-item closing-bottom-up-item--apply motion-section civic-grid px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
	<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.82fr_minmax(0,48rem)] lg:items-start">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-purple)]">
				APPLICATION
			</p>
			<h2 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
				Apply for Hack The Future
			</h2>
			<p class="mt-5 max-w-2xl text-base leading-7 text-[var(--color-muted)]">
				Register your interest below.
			</p>
			<p class="mt-2 text-sm leading-6 text-[var(--color-muted)]/72">
				Applications open: Date to be confirmed
			</p>
		</div>

		<div class="w-full">
			<ApplicationForm />
		</div>
	</div>
</section>

<section id="about" class="closing-bottom-up-item closing-bottom-up-item--about motion-section civic-grid px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
	<div class="mx-auto max-w-7xl">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-purple)]">
					PARTNERS
				</p>
				<h2 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
					Who's behind it
				</h2>
			</div>
			<div class="space-y-6 text-base leading-8 text-[var(--color-muted)]">
				<p>Hack the Future is part of CATALIZATOR, the leadership and governance platform hosted by the Municipality of Shumen.</p>
				<p>CATALIZATOR brings together mayors, business leaders and academics to work on the future of cities.</p>
				<p>Hack the Future brings the same questions to the people who will live with the answers longest.</p>
				<p class="font-semibold text-[var(--color-ink)]">That's you.</p>
			</div>
		</div>

		<div class="mt-12 grid gap-x-12 gap-y-4 md:grid-cols-2">
			{partners.map((partner, index) => (
				<article class="partner-row group border-t border-[var(--color-line)] py-7">
					<p class="text-xs font-semibold text-[var(--color-muted)]/42">0{index + 1}</p>
					<h3 class="mt-5 text-[1.08rem] font-semibold uppercase leading-7 tracking-[0.17em] text-[var(--color-ink)] transition-colors duration-200 group-hover:text-[var(--color-purple)]">
						{partner.name}
					</h3>
					<p class="mt-2 text-sm font-medium leading-6 text-[var(--color-muted)]">
						{partner.subtitle}
					</p>
				</article>
			))}
		</div>
	</div>
</section>

<section class="closing-bottom-up-item closing-bottom-up-item--why motion-section cinematic-dark matrix-clear-right px-4 py-16 text-[var(--color-paper)] sm:px-6 sm:py-20 lg:px-8 lg:py-24">
	<div class="relative z-10 mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-start">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-paper)]/54">
				WHY THIS EXISTS
			</p>
			<h2 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] sm:text-4xl lg:text-5xl">
				The country you're about to inherit is changing faster than the systems built to run it.
			</h2>
		</div>

		<div class="max-w-2xl">
			<div class="mt-1 text-base leading-8 text-[var(--color-paper)]/72">
				<div class="why-copy-group pb-7">
					<p>The country you are about to inherit is changing faster than the systems built to run it. Work, climate, technology, your city, your own mental health, the economy — none of it looks the way it did even ten years ago, and none of it is going to slow down.</p>
				</div>

				<div class="why-copy-group py-7">
					<p>No one has the full playbook for what comes next. Not your teachers. Not your parents. Not the mayors. Not us.</p>
					<p class="mt-5">The honest truth is that the people who will live longest with the decisions being made right now are the ones with the least say in them.</p>
				</div>

				<div class="why-copy-group pt-4">
					<p class="text-xl font-semibold leading-8 text-[rgba(222,213,193,0.88)] sm:text-2xl sm:leading-9">Hack the Future exists to change that.</p>
					<p class="mt-6">The work you do in these two days is not symbolic.</p>
					<p class="mt-5 border-l border-[rgba(222,213,193,0.88)] py-1 pl-7">Mentors take it seriously.<br />The jury takes it seriously.<br />Partners take it seriously.</p>
					<p class="mt-6">The strongest ideas become the starting point for real conversations with institutions that can act on them.</p>
				</div>
			</div>
		</div>
	</div>
</section>

</div>

<style>
	.closing-bottom-up-stack {
		display: flex;
		flex-direction: column;
	}

	.closing-bottom-up-stack > * {
		width: 100%;
	}

	.closing-bottom-up-item--why {
		order: 1;
	}

	.closing-bottom-up-item--about {
		order: 2;
	}

	.closing-bottom-up-item--apply {
		order: 3;
	}

	.closing-bottom-up-item--brand {
		order: 4;
	}

	.closing-bottom-up-item--who {
		order: 5;
	}

	.participation-list {
		align-content: start;
	}

	.participation-list-column {
		display: grid;
		align-content: start;
	}

	.brand-divider {
		position: relative;
		overflow: hidden;
		background:
			linear-gradient(90deg, rgba(124, 58, 237, 0.18), transparent 14%, transparent 86%, rgba(240, 76, 255, 0.14)),
			repeating-linear-gradient(90deg, rgba(124, 58, 237, 0.08) 0 1px, transparent 1px 4rem),
			repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.055) 0 1px, transparent 1px 5px),
			#0A0A0A;
		box-shadow:
			inset 0 1px 0 rgba(124, 58, 237, 0.38),
			inset 0 -1px 0 rgba(240, 76, 255, 0.22),
			0 0 28px rgba(124, 58, 237, 0.1);
	}

	.brand-divider-mask {
		contain: strict;
		height: 2.4rem;
		min-width: 0;
		overflow: clip;
		padding-bottom: 0;
		padding-top: 0;
		position: relative;
		width: 100%;
	}

	.brand-divider::before,
	.brand-divider::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.brand-divider::before {
		background:
			linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.22), transparent),
			linear-gradient(180deg, transparent 0 42%, rgba(240, 76, 255, 0.12) 42% 44%, transparent 44% 100%);
		opacity: 0.34;
		transform: translateX(-38%);
		animation: brand-divider-scan 6.5s linear infinite;
	}

	.brand-divider::after {
		background:
			linear-gradient(90deg, #0A0A0A 0%, transparent 9%, transparent 91%, #0A0A0A 100%),
			radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.16), transparent 58%);
		mix-blend-mode: screen;
		opacity: 0.7;
	}

	.brand-divider-track {
		left: 0;
		position: absolute;
		top: 50%;
		z-index: 1;
		width: max-content;
		white-space: nowrap;
		will-change: transform;
		animation: brand-divider-scroll 28s linear infinite;
	}

	.brand-divider-sequence span {
		color: rgba(255, 255, 255, 0.8);
		text-shadow: 0 0 0.45rem rgba(124, 58, 237, 0.22);
	}

	.brand-divider-mark {
		width: 0.9rem;
		height: 0.9rem;
		color: rgba(183, 140, 255, 0.86);
		opacity: 0.9;
		stroke: currentColor;
		stroke-width: 5;
		stroke-linecap: round;
		stroke-linejoin: round;
		filter: drop-shadow(0 0 0.38rem rgba(124, 58, 237, 0.24));
	}

	.brand-divider-mark-dot {
		fill: var(--color-accent);
		stroke: none;
		filter: drop-shadow(0 0 0.34rem rgba(124, 58, 237, 0.48));
	}

	@keyframes brand-divider-scan {
		from {
			transform: translateX(-42%);
		}

		to {
			transform: translateX(42%);
		}
	}

	@keyframes brand-divider-scroll {
		from {
			transform: translate3d(0, -50%, 0);
		}

		to {
			transform: translate3d(-50%, -50%, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.brand-divider-track {
			animation-duration: 28s !important;
		}
	}
</style>
