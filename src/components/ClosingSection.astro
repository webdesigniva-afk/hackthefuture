<script>
	const participationTimelines = Array.from(document.querySelectorAll<HTMLElement>("[data-participation-timeline]"));
	const participationReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (participationReducedMotion) {
		participationTimelines.forEach((timeline) => {
			timeline.classList.add("is-visible");
			timeline.querySelectorAll<HTMLElement>(".participation-timeline-item").forEach((item) => item.classList.add("is-item-visible"));
		});
	} else {
		const isBottomUpParticipation = document.body.dataset.scrollFlow === "bottom-up";
		let lastParticipationScrollY = window.scrollY;
		let hasMovedTowardParticipation = !isBottomUpParticipation || Boolean(window.location.hash);
		let participationObserver: IntersectionObserver | undefined;

		const revealParticipationTimeline = (timeline: HTMLElement) => {
			timeline.classList.add("is-visible");
			const timelineItems = Array.from(timeline.querySelectorAll<HTMLElement>(".participation-timeline-item")).reverse();

			timelineItems.forEach((item, index) => {
				window.setTimeout(() => {
					item.classList.add("is-item-visible");
				}, index * 540);
			});

			participationObserver?.unobserve(timeline);
		};

		const checkParticipationTimelines = () => {
			const currentScrollY = window.scrollY;
			if (isBottomUpParticipation ? currentScrollY < lastParticipationScrollY - 2 : currentScrollY > lastParticipationScrollY + 2) {
				hasMovedTowardParticipation = true;
			}
			lastParticipationScrollY = currentScrollY;

			const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

			participationTimelines.forEach((timeline) => {
				if (timeline.classList.contains("is-visible")) return;

				const revealTarget = timeline.closest<HTMLElement>(".closing-bottom-up-item") ?? timeline;
				const rect = revealTarget.getBoundingClientRect();
				const hasReachedTimeline = isBottomUpParticipation
					? rect.top < viewportHeight * 0.66 && rect.bottom > viewportHeight * 0.54
					: rect.top < viewportHeight * 0.72 && rect.bottom > viewportHeight * 0.2;

				if (hasMovedTowardParticipation && hasReachedTimeline) {
					revealParticipationTimeline(timeline);
				}
			});

			if (participationTimelines.every((timeline) => timeline.classList.contains("is-visible"))) {
				window.removeEventListener("scroll", requestParticipationCheck);
				window.removeEventListener("resize", requestParticipationCheck);
				window.removeEventListener("load", requestParticipationCheck);
				participationObserver?.disconnect();
			}
		};

		let participationTicking = false;
		function requestParticipationCheck() {
			if (participationTicking) return;
			participationTicking = true;
			window.requestAnimationFrame(() => {
				participationTicking = false;
				checkParticipationTimelines();
			});
		}

		const startParticipationTimeline = () => {
			if (participationTimelines.every((timeline) => timeline.classList.contains("is-visible"))) return;

			if (!isBottomUpParticipation && "IntersectionObserver" in window) {
				participationObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting && entry.target instanceof HTMLElement) {
								revealParticipationTimeline(entry.target);
							}
						});
					},
					{ threshold: 0.24, rootMargin: "0px 0px -18% 0px" }
				);

				participationTimelines.forEach((timeline) => participationObserver?.observe(timeline));
			}

			window.addEventListener("scroll", requestParticipationCheck, { passive: true });
			window.addEventListener("resize", requestParticipationCheck);
			window.addEventListener("load", requestParticipationCheck, { once: true });
			requestParticipationCheck();
			window.setTimeout(requestParticipationCheck, 160);
			window.setTimeout(requestParticipationCheck, 420);
		};

		const waitForBottomUpBoot = () => {
			if (!isBottomUpParticipation || !document.documentElement.classList.contains("is-bottom-up-booting")) {
				startParticipationTimeline();
				return;
			}

			window.requestAnimationFrame(waitForBottomUpBoot);
		};

		waitForBottomUpBoot();
	}
</script>
