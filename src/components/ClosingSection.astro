		background:
			radial-gradient(circle at 16% 50%, rgba(124, 58, 237, 0.32), transparent 24rem),
			radial-gradient(circle at 84% 50%, rgba(240, 76, 255, 0.18), transparent 22rem),
			linear-gradient(90deg, rgba(124, 58, 237, 0.18), transparent 14%, transparent 86%, rgba(240, 76, 255, 0.14)),
			repeating-linear-gradient(90deg, rgba(167, 139, 250, 0.11) 0 1px, transparent 1px 4.6rem),
			repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.055) 0 1px, transparent 1px 5px),
			var(--brand-divider-deep);
		box-shadow:
			inset 0 1px 0 rgba(196, 181, 253, 0.48),
