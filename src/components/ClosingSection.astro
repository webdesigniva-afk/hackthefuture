---
import ApplicationForm from "./ApplicationForm.astro";
import AtmosphericAnchor from "./AtmosphericAnchor.astro";
import { getLang, type Lang } from "../i18n";

interface Props {
	lang?: Lang;
}

const lang = getLang(Astro.props.lang);
const checklistBase = [
	{ icon: "M12 3v18M5 8h14M7 16h10", size: "tall" },
	{ icon: "M12 21s7-5.1 7-11a7 7 0 0 0-14 0c0 5.9 7 11 7 11Z M12 10.5h.01", size: "short" },
	{ icon: "M8 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM16 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3 21a5 5 0 0 1 10 0M13.5 20.5a4.5 4.5 0 0 1 7.5 0", size: "short" },
	{ icon: "M4 10l8-5 8 5-8 5-8-5ZM6 12v5c1.5 1.4 3.5 2 6 2s4.5-.6 6-2v-5", size: "tall" },
	{ icon: "M20 6 9 17l-5-5", size: "wide" },
];
const participationCopy = {
	en: {
		title: "Who can join",
		kicker: "PARTICIPATION",
		items: [
			"Students aged 15 to 19",
			"From Shumen or anywhere in Bulgaria",
			"Apply alone or with a team",
			"Schools can nominate students",
			"No experience required",
		],
	},
	bg: {
		title: "Кой може да участва",
		kicker: "УЧАСТИЕ",
		items: [
			"Младежи на възраст между 15 и 19 години",
			"От Шумен или от всяка друга точка на България",
			"Кандидатствай самостоятелно или като част от екип",
			"Училищата могат да номинират ученици",
			"Не е необходим предишен опит",
		],
	},
}[lang];
const applicationCopy = {
	en: {
		title: "Apply for Hack The Future",
		kicker: "APPLICATION",
	},
	bg: {
		title: "Кандидатствай за Hack The Future",
		kicker: "КАНДИДАТСТВАНЕ",
	},
}[lang];
const aboutCopy = {
	en: {
		title: "Who's behind it",
		kicker: "ABOUT",
		partners: [
			{
				name: "Municipality of Shumen",
				subtitle: "Host institution",
			},
			{
				name: "Sofia Tech Park",
				subtitle: "Innovation partner",
			},
			{
				name: "Shumen Institute of Technology",
				subtitle: "Academic partner",
			},
		],
		body: [
			"Hack The Future is part of CATALIZATOR, the leadership and governance platform hosted by the Municipality of Shumen.",
			"CATALIZATOR brings together mayors, business leaders, and academics to work on the future of cities.",
			"Hack The Future brings the same questions to the people who will live with the answers longest. That's you.",
		],
	},
	bg: {
		title: "Кой стои зад инициативата",
		kicker: "ЗА ИНИЦИАТИВАТА",
		partners: [
			{
				name: "Община Шумен",
				subtitle: "Домакин на инициативата",
			},
			{
				name: "Sofia Tech Park",
				subtitle: "Партньор за иновации",
			},
			{
				name: "Шуменски технологичен институт",
				subtitle: "Академичен партньор",
			},
		],
		body: [
			"Hack The Future е част от CATALIZATOR - платформа за лидерство и добро управление, създадена с подкрепата на Община Шумен.",
			"CATALIZATOR събира на едно място кметове, представители на бизнеса и академичната общност, за да работят заедно по бъдещето на градовете.",
			"Hack The Future поставя същите въпроси пред хората, които ще живеят най-дълго с техните отговори. Това сте вие.",
		],
	},
}[lang];
const whyCopy = {
	en: {
		title: "The country you're about to inherit is changing faster than the systems built to run it.",
		lead: "Work, climate, technology, your city, your own mental health, the economy. None of it looks the way it did even ten years ago, and none of it is going to slow down.",
		kicker: "WHY THIS EXISTS",
		intro: "The country you're about to inherit is changing faster than the systems built to run it. Work, climate, technology, your city, your own mental health, the economy. None of it looks the way it did even ten years ago, and none of it is going to slow down.",
		noPlaybook: "No one has the full playbook for what comes next. Not your teachers. Not your parents. Not the mayors. Not us.",
		truth: "The honest truth is this. The people who will live longest with the decisions being made right now are the ones with the least say in them.",
		statement: "Hack The Future exists to change that.",
		work: "The work you do in these two days is not symbolic.",
		serious: ["Mentors take it seriously.", "The jury takes it seriously.", "Partners take it seriously."],
		outcome: "The strongest ideas become the starting point for real conversations with institutions that can act on them.",
	},
	bg: {
		title: "Държавата, която предстои да наследите, се променя по-бързо от системите, създадени да я управляват.",
		lead: "Работата. Климатът. Технологиите. Вашият град. Вашата емоционална устойчивост. Икономиката. Нищо от това не изглежда така, както изглеждаше преди десет години. И промяната няма да се забави.",
		kicker: "ЗАЩО СЪЩЕСТВУВА ТАЗИ ИНИЦИАТИВА",
		intro: "Държавата, която предстои да наследите, се променя по-бързо от системите, създадени да я управляват. Работата. Климатът. Технологиите. Вашият град. Вашата емоционална устойчивост. Икономиката. Нищо от това не изглежда така, както изглеждаше преди десет години. И промяната няма да се забави.",
		noPlaybook: "Никой не разполага с готов отговор за това какво предстои. Нито вашите учители. Нито вашите родители. Нито кметовете. Нито ние.",
		truth: "Истината е проста. Хората, които ще живеят най-дълго с последствията от решенията, които се вземат днес, често имат най-малък глас при вземането им.",
		statement: "Hack The Future съществува, за да промени това.",
		work: "Работата, която ще свършите през тези два дни, не е символична.",
		serious: ["Менторите ще я приемат сериозно.", "Журито ще я приеме сериозно.", "Партньорите ще я приемат сериозно."],
		outcome: "Най-силните идеи могат да се превърнат в началото на реални разговори с институции и организации, които имат възможност да ги превърнат в реалност.",
	},
}[lang];
const checklist = checklistBase.map((item, index) => ({
	...item,
	title: participationCopy.items[index],
}));
const brandDividerItems = [
	"CATALIZATOR",
	"HACK THE FUTURE",
	...(lang === "bg"
		? ["ОБЩИНА ШУМЕН", "СОФИЯ ТЕХ ПАРК", "ШУМЕНСКИ ТЕХНОЛОГИЧЕН ИНСТИТУТ"]
		: ["SHUMEN MUNICIPALITY", "SOFIA TECH PARK", "SHUMEN INSTITUTE OF TECHNOLOGY"]),
	"FUTURE READINESS CHALLENGE",
	...(lang === "bg"
		? [
				"МЛАДИ ХОРА",
				"Бъдещето на труда",
				"Околна среда и реакция при кризи",
				"Емоционална устойчивост и благополучие на младите хора",
				"Местни продукти, храни и бизнес на бъдещето",
			]
		: [
				"FUTURE OF WORK",
				"ENVIRONMENT & CRISIS RESPONSE",
				"MENTAL HEALTH & YOUTH WELLBEING",
				"LOCAL PRODUCTS, FOOD & FUTURE BUSINESS",
				"YOUNG PEOPLE",
			]),
];

---

<div class="closing-bottom-up-stack">
<section id="who-can-join" class="closing-bottom-up-item closing-bottom-up-item--who motion-section civic-grid px-4 py-12 sm:px-6 sm:py-14 lg:px-8 lg:py-16" data-participation-lang={lang}>
	<div class="participation-layout relative mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(17rem,0.44fr)_minmax(0,1fr)] lg:items-start lg:gap-8 xl:gap-10">
		<div class="participation-heading">
			<h2 class="closing-section-title max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
				{participationCopy.title}
			</h2>
		</div>

		<div class="participation-list participation-timeline grid gap-6 lg:pt-1" data-participation-timeline>
			{checklist.map((item) => (
				<div
					class="participation-timeline-item participation-timeline-item--right"
				>
					<div class="participation-timeline-copy">
						<span class="participation-timeline-rule" aria-hidden="true"></span>
						<h3 class="text-base font-semibold leading-7 tracking-[-0.015em] text-[var(--color-ink)]">
							{item.title}
						</h3>
					</div>
					<span class="participation-icon participation-timeline-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							<path d={item.icon} />
						</svg>
					</span>
				</div>
			))}
		</div>

		<p class="section-kicker participation-kicker">
			{participationCopy.kicker}
		</p>
	</div>
</section>

<div class="closing-bottom-up-item closing-bottom-up-item--brand brand-divider px-4 py-2 sm:px-6 lg:px-8" aria-hidden="true">
	<div class="brand-divider-mask mx-auto flex max-w-7xl items-center overflow-hidden py-3">
		<div class="brand-divider-track flex items-center gap-5 text-[0.66rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-paper)]/76">
			{Array.from({ length: 4 }).map(() => (
				<div class="brand-divider-sequence flex items-center gap-5 pr-5">
					{brandDividerItems.map((item) => (
						<>
							<span>{item}</span>
							<svg viewBox="0 0 128 128" class="brand-divider-mark" fill="none" aria-hidden="true">
								<circle cx="64" cy="64" r="42" />
								<path d="M64 8V31M64 97v23M8 64h23M97 64h23" />
								<path d="M64 31C58 48 48 58 31 64M64 31c6 17 16 27 33 33M64 97C58 80 48 70 31 64M64 97c6-17 16-27 33-33" />
								<circle cx="64" cy="64" r="9" class="brand-divider-mark-dot" />
							</svg>
						</>
					))}
				</div>
			))}
		</div>
	</div>
</div>

<div class="closing-bottom-up-item closing-bottom-up-item--atmospheric">
	<AtmosphericAnchor lang={lang} />
</div>

<section id="apply" class="closing-bottom-up-item closing-bottom-up-item--apply motion-section civic-grid px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
	<div class="application-layout mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(18rem,0.72fr)_minmax(0,48rem)] lg:items-start lg:gap-14 xl:gap-20">
		<div class="application-copy">
			<h2 class="closing-section-title max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
				{applicationCopy.title}
			</h2>
		</div>

		<div class="w-full">
			<ApplicationForm lang={lang} />
		</div>

		<p class="section-kicker application-kicker">
			{applicationCopy.kicker}
		</p>
	</div>
</section>

<section id="about" class="closing-bottom-up-item closing-bottom-up-item--about motion-section civic-grid px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
	<div class="mx-auto max-w-7xl">
		<div class="about-main grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
			<div class="about-heading">
				<h2 class="closing-section-title max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[var(--color-ink)] sm:text-4xl lg:text-5xl">
					{lang === "bg" ? <>Кой стои зад<br />инициативата</> : aboutCopy.title}
				</h2>
			</div>
			<div class="about-content">
				<div class="partner-index">
					{aboutCopy.partners.map((partner) => (
						<article class="partner-row group">
							<h3 class="partner-name">
								{partner.name}
							</h3>
							<p class="partner-role">
								{partner.subtitle}
							</p>
						</article>
					))}
				</div>

				<div class="about-copy text-base leading-7 text-[var(--color-muted)]">
					{aboutCopy.body.map((paragraph) => (
						<p>{paragraph}</p>
					))}
				</div>
			</div>

			<p class="section-kicker about-bottom-kicker">
				{aboutCopy.kicker}
			</p>
		</div>
	</div>
</section>

<section class="closing-bottom-up-item closing-bottom-up-item--why motion-section cinematic-dark px-4 py-16 text-[var(--color-paper)] sm:px-6 sm:py-20 lg:px-8 lg:py-24" data-why-lang={lang}>
	<div class="why-exists-layout relative z-10 mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-stretch">
		<div class="why-exists-heading flex h-full flex-col gap-8">
			<h2 class="why-exists-title mt-1 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] sm:text-4xl lg:text-5xl">
				{whyCopy.title}
			</h2>
			<p class="max-w-xl text-base leading-7 text-[var(--color-paper)]/72">
				{whyCopy.lead}
			</p>
			<p class="section-kicker why-exists-kicker">
				{whyCopy.kicker}
			</p>
		</div>

		<div class="why-exists-copy">
			<div class="why-exists-copy-flow mt-1 text-base leading-7 text-[var(--color-paper)]/72">
				<div class="why-copy-column">
				<div class="why-copy-group">
					<p>{whyCopy.intro}</p>
				</div>

				<div class="why-copy-group">
					<p>{whyCopy.noPlaybook}</p>
					<p class="mt-5">{whyCopy.truth}</p>
				</div>
				</div>

				<div class="why-copy-column">
				<div class="why-copy-group">
					<p class="text-xl font-semibold leading-7 text-[rgba(196,181,253,0.9)] sm:text-2xl sm:leading-8">{whyCopy.statement}</p>
					<p class="mt-6">{whyCopy.work}</p>
					<p class="mt-5 border-l border-[rgba(196,181,253,0.78)] py-1 pl-7">{whyCopy.serious.map((line) => <>{line}<br /></>)}</p>
					<p class="mt-6">{whyCopy.outcome}</p>
				</div>
				</div>
			</div>
		</div>
	</div>
</section>

</div>

<style>
	.closing-bottom-up-stack {
		display: flex;
		flex-direction: column;
	}

	.closing-bottom-up-stack > * {
		width: 100%;
	}

	.closing-bottom-up-item--why {
		order: 1;
	}

	.why-exists-kicker {
		margin-top: auto;
		color: rgba(196, 181, 253, 0.9);
	}

	.why-exists-title {
		font-size: clamp(2rem, 3.05vw, 3.45rem);
		line-height: 1.08;
		text-wrap: balance;
	}

	.why-exists-copy-flow,
	.why-exists-copy-grid {
		display: grid;
		gap: 2rem;
		line-height: 1.62rem;
	}

	.why-exists-copy-flow > .why-copy-column {
		display: contents;
	}

	.why-exists-copy-flow > .why-copy-column:first-child > .why-copy-group:first-child {
		display: none;
	}

	.why-copy-column {
		display: grid;
		align-content: start;
		gap: 2rem;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-layout {
		gap: clamp(3rem, 5.2vw, 5.5rem);
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-heading {
		gap: clamp(1.7rem, 3vw, 2.35rem);
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-title {
		max-width: 12.6em;
		font-size: clamp(2.05rem, 3.05vw, 3.55rem);
		font-weight: 600;
		letter-spacing: -0.022em;
		line-height: 1.08;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-heading > p:not(.section-kicker) {
		max-width: 38rem;
		font-size: 0.98rem;
		letter-spacing: 0.004em;
		line-height: 1.6;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-copy-flow {
		max-width: 58rem;
		gap: clamp(2rem, 3vw, 2.5rem);
		font-size: 0.98rem;
		letter-spacing: 0.003em;
		line-height: 1.64;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-copy-group {
		max-width: 54rem;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-copy-group p {
		text-wrap: pretty;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-copy-group p.text-xl {
		font-size: clamp(1.34rem, 1.72vw, 1.84rem);
		letter-spacing: -0.014em;
		line-height: 1.34;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-copy-group p.border-l {
		padding-left: 2rem;
		line-height: 1.64;
	}

	.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-kicker {
		max-width: 24rem;
		letter-spacing: 0.2em;
		line-height: 1.6;
	}

	@media (min-width: 1024px) {
		.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-layout {
			grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
			align-items: center;
		}
	}

	@media (max-width: 767px) {
		.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-title {
			max-width: 11em;
			font-size: clamp(2rem, 9vw, 2.95rem);
			line-height: 1.12;
		}

		.closing-bottom-up-item--why[data-why-lang="bg"] .why-exists-copy-flow {
			font-size: 0.95rem;
			line-height: 1.56;
		}
	}

	@media (min-width: 768px) {
		.why-exists-copy-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: clamp(2rem, 4vw, 4.5rem);
		}
	}

	.closing-bottom-up-item--about {
		order: 2;
	}

	.closing-bottom-up-item--atmospheric {
		order: 3;
	}

	.closing-bottom-up-item--apply {
		order: 4;
	}

	.closing-bottom-up-item--brand {
		order: 5;
	}

	.closing-bottom-up-item--who {
		order: 6;
	}

	.closing-bottom-up-stack .closing-section-title {
		font-size: clamp(2rem, 3.15vw, 3rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
	}

	.closing-bottom-up-item--apply {
		overflow: visible;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(248, 246, 255, 0.86) 18%, rgba(250, 248, 255, 0.96) 58%, rgba(255, 255, 255, 0) 100%),
			radial-gradient(circle at 13% 18%, rgba(124, 58, 237, 0.08), transparent 26rem),
			radial-gradient(circle at 82% 54%, rgba(183, 140, 255, 0.065), transparent 30rem);
	}

	.closing-bottom-up-item--apply::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background:
			linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.16), transparent) top center / min(74rem, calc(100% - 2rem)) 1px no-repeat,
			linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.1), transparent) bottom center / min(68rem, calc(100% - 2rem)) 1px no-repeat;
		opacity: 0.72;
	}

	.application-copy {
		position: relative;
		align-self: start;
		padding-top: 0.15rem;
	}

	.application-copy::after {
		content: "";
		display: block;
		width: min(11rem, 46%);
		height: 1px;
		margin-top: clamp(2rem, 5vw, 4.5rem);
		background: linear-gradient(90deg, rgba(10, 10, 10, 0.36), rgba(124, 58, 237, 0.26), transparent);
	}

	@media (min-width: 1024px) {
		.application-copy {
			position: sticky;
			top: 120px;
		}
	}

	.participation-list {
		align-content: start;
	}

	@media (min-width: 1024px) {
		.participation-heading {
			position: sticky;
			top: 120px;
			align-self: start;
			z-index: 2;
		}

		.participation-heading::after {
			content: "";
			display: block;
			width: min(11rem, 46%);
			height: 1px;
			margin-top: clamp(2rem, 5vw, 4.5rem);
			background: linear-gradient(90deg, rgba(10, 10, 10, 0.36), rgba(124, 58, 237, 0.26), transparent);
		}

		.participation-kicker {
			grid-column: 1 / -1;
			margin-top: 2rem;
		}
	}

	.participation-timeline {
		margin-inline: 0;
		max-width: min(100%, 45rem);
	}

	.participation-timeline-item {
		--participation-delay: 0ms;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 1.5rem minmax(0, 1fr);
		column-gap: clamp(0.85rem, 2vw, 1.35rem);
		align-items: center;
		opacity: 0;
		filter: blur(10px);
		transform: translate3d(var(--participation-enter-x), 20px, 0);
		transition:
			opacity 920ms cubic-bezier(0.16, 1, 0.3, 1),
