	.brand-divider::before {
		background:
			linear-gradient(90deg, transparent 0 30%, rgba(255, 255, 255, 0.18) 47%, rgba(167, 139, 250, 0.34) 50%, rgba(240, 76, 255, 0.18) 53%, transparent 70%),
			linear-gradient(180deg, transparent 0 47%, rgba(240, 76, 255, 0.16) 47% 50%, transparent 50% 100%);
		opacity: 0.42;
		transform: translateX(-46%);
		animation: brand-divider-scan 7.8s linear infinite;
	}

	.brand-divider::after {
		background:
			linear-gradient(90deg, var(--brand-divider-deep) 0%, transparent 10%, transparent 90%, var(--brand-divider-deep) 100%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 24%, transparent 76%, rgba(124, 58, 237, 0.1)),
			radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.22), transparent 62%);
