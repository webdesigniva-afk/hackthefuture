---
import "../styles/global.css";
import HTFCursorTrail from "../components/HTFCursorTrail.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import { getLang, siteCopy, type Lang } from "../i18n";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	lang?: Lang;
	bottomUp?: boolean;
}

const {
	title = "CATALIZATOR",
	description = "A leadership platform for institutional decision-makers.",
	image = "/catalizator-logo.png",
	lang: langProp = "en",
	bottomUp = false,
} = Astro.props;

const lang = getLang(langProp);
---

<!doctype html>
<html lang={lang} data-scroll-flow={bottomUp ? "bottom-up" : undefined}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/catalizator-logo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#FFFFFF" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="CATALIZATOR" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<title>{title}</title>
		{bottomUp && (
			<script is:inline>
				if (!window.location.hash) {
					document.documentElement.classList.add("is-bottom-up-booting");
					if ("scrollRestoration" in history) {
						history.scrollRestoration = "manual";
					}
				}
			</script>
		)}
	</head>
	<body data-scroll-flow={bottomUp ? "bottom-up" : undefined}>
		<slot />
		<HTFCursorTrail />
		<ScrollToTop label={bottomUp && lang === "en" ? "Back to start" : siteCopy[lang].scrollToTop} />
		<script>
			const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			const isBottomUp = document.body.dataset.scrollFlow === "bottom-up";
			const siteHeader = document.querySelector("[data-site-header]");
			const scrollToTopButton = document.querySelector("[data-scroll-to-top]");
			const galleryComposition = document.querySelector("[data-gallery-composition]");
			const sectionCandidates = document.querySelectorAll("main > section, article > section, body > section");
			const cardCandidates = document.querySelectorAll(".quiet-card, .premium-hover, .publication-entry");
			const motionTargets = new Set();

			sectionCandidates.forEach((section) => {
				if (!section.classList.contains("hero-section")) {
					section.classList.add("motion-section");
				}
			});

			cardCandidates.forEach((item) => item.classList.add("motion-item"));

			document.querySelectorAll(".grid, ol, ul").forEach((group) => {
				const items = Array.from(group.children)
					.map((child) =>
						child.matches(".motion-item, .quiet-card, .premium-hover, .publication-entry")
							? child
							: child.querySelector(":scope > .publication-entry")
					)
					.filter(Boolean);

				if (items.length > 1) {
					group.classList.add("motion-stagger");
					items.forEach((item, index) => {
						if (item instanceof HTMLElement) {
							item.style.setProperty("--motion-delay", `${Math.min(index, 4) * 55}ms`);
						}
					});
				}
			});

			document.querySelectorAll(".motion-section, .motion-item").forEach((target) => motionTargets.add(target));

			if (reducedMotion) {
				motionTargets.forEach((target) => target.classList.add("is-visible", "motion-ready"));
				galleryComposition?.classList.add("gallery-is-connected");
			} else {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								window.setTimeout(() => entry.target.classList.add("motion-ready"), 820);
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12, rootMargin: "0px 0px -10% 0px" }
				);

				motionTargets.forEach((target) => observer.observe(target));

				if (galleryComposition) {
					const galleryObserver = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add("gallery-is-connected");
									galleryObserver.unobserve(entry.target);
								}
							});
						},
						{ threshold: 0.42, rootMargin: "-14% 0px -18% 0px" }
					);

					galleryObserver.observe(galleryComposition);
				}
			}

			if (scrollToTopButton) {
				const getBottomScroll = () => Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
				const updateScrollToTop = () => {
					const distanceFromStart = isBottomUp ? getBottomScroll() - window.scrollY : window.scrollY;
					scrollToTopButton.classList.toggle("is-visible", distanceFromStart > 720);
				};

				scrollToTopButton.addEventListener("click", () => {
					window.scrollTo({ top: isBottomUp ? getBottomScroll() : 0, behavior: reducedMotion ? "auto" : "smooth" });
				});

				updateScrollToTop();
				window.addEventListener("scroll", updateScrollToTop, { passive: true });
			}

			if (siteHeader instanceof HTMLElement) {
				let headerThemeTicking = false;
				const updateHeaderTheme = () => {
					const rect = siteHeader.getBoundingClientRect();
					const probeX = Math.max(1, Math.min(window.innerWidth - 1, window.innerWidth / 2));
					const probeY = isBottomUp
						? Math.max(1, Math.min(window.innerHeight - 1, rect.top - 2))
						: Math.max(1, Math.min(window.innerHeight - 1, rect.bottom + 2));
					const elementBelowHeader = document.elementFromPoint(probeX, probeY);
					const isOverHero = Boolean(elementBelowHeader?.closest(".hero-section"));

					siteHeader.classList.toggle("is-over-hero", isOverHero);
					headerThemeTicking = false;
				};

				const requestHeaderTheme = () => {
					if (!headerThemeTicking) {
						window.requestAnimationFrame(updateHeaderTheme);
						headerThemeTicking = true;
					}
				};

				updateHeaderTheme();
				window.addEventListener("scroll", requestHeaderTheme, { passive: true });
				window.addEventListener("resize", requestHeaderTheme, { passive: true });
				window.addEventListener("load", requestHeaderTheme, { once: true });
			}

			if (isBottomUp && !window.location.hash) {
				let bottomUpReleased = false;
				let userMovedAfterRelease = false;
				const getBottomStart = () => Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
				const pinToBottomStart = () => {
					if (!userMovedAfterRelease) {
						window.scrollTo({ top: getBottomStart(), behavior: "auto" });
					}
				};
				const scrollToBottomStart = () => {
					pinToBottomStart();
					window.requestAnimationFrame(() => {
						pinToBottomStart();
						window.requestAnimationFrame(() => {
							pinToBottomStart();
							bottomUpReleased = true;
							document.documentElement.classList.remove("is-bottom-up-booting");
						});
					});
				};
				const markUserMoved = () => {
					if (bottomUpReleased) {
						userMovedAfterRelease = true;
					}
				};

				scrollToBottomStart();
				window.setTimeout(pinToBottomStart, 120);
				window.setTimeout(pinToBottomStart, 360);
				document.fonts?.ready?.then(() => window.setTimeout(pinToBottomStart, 0));
				window.addEventListener("load", scrollToBottomStart, { once: true });
				window.addEventListener("wheel", markUserMoved, { passive: true });
				window.addEventListener("touchstart", markUserMoved, { passive: true });
				window.addEventListener("keydown", markUserMoved);
				window.addEventListener("pageshow", (event) => {
					if (event.persisted) {
						scrollToBottomStart();
					}
				});
			}
		</script>
	</body>
</html>
