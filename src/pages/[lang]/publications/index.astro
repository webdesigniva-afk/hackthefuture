---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PublicationCard from "../../../components/PublicationCard.astro";
import { getPublications } from "../../../data/publications";
import { languages, siteCopy, type Lang } from "../../../i18n";

export function getStaticPaths() {
	return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;

if (!languages.includes(lang)) {
	return Astro.redirect("/publications", 302);
}

const t = siteCopy[lang];
const [featuredPublication, ...remainingPublications] = await getPublications(lang);
---

<BaseLayout title={t.meta.publicationsTitle} description={t.meta.publicationsDescription} lang={lang}>
	<Header lang={lang} />
	<main>
		<section class="motion-section gradient-rule px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_26rem] lg:items-end">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-purple)]">
							{t.publicationsPage.eyebrow}
						</p>
						<h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight tracking-[-0.045em] text-[var(--color-ink)] sm:text-5xl lg:text-6xl">
							{t.publicationsPage.title}
						</h1>
					</div>
					<p class="text-base leading-8 text-[var(--color-muted)]">
						{t.publicationsPage.intro}
					</p>
				</div>
			</div>
		</section>

		<section class="motion-section px-4 pb-16 sm:px-6 sm:pb-20 lg:px-8 lg:pb-24">
			<div class="mx-auto max-w-7xl">
				{featuredPublication && <PublicationCard publication={featuredPublication} featured lang={lang} />}

				<div class="mt-7 grid items-stretch gap-x-5 gap-y-8 md:grid-cols-2 lg:grid-cols-3">
					{remainingPublications.map((publication, index) => (
						<div class={index % 3 === 1 ? "lg:translate-y-6" : index % 3 === 2 ? "lg:translate-y-2" : ""}>
							<PublicationCard publication={publication} lang={lang} />
						</div>
					))}
				</div>

				<nav class="mt-12 flex items-center justify-between border-t border-[var(--color-line)] pt-6 text-sm text-[var(--color-muted)]" aria-label={t.publicationsPage.pagination}>
					<span>{t.publicationsPage.pagination}</span>
					<div class="flex gap-3">
						<span class="opacity-45">{t.publicationsPage.previous}</span>
						<span class="text-[var(--color-purple)]">{t.publicationsPage.next}</span>
					</div>
				</nav>
			</div>
		</section>
	</main>
	<Footer lang={lang} />
</BaseLayout>
