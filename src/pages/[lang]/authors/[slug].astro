---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PublicationCard from "../../../components/PublicationCard.astro";
import { getAuthor, getAuthors, getPublicationsByAuthor } from "../../../data/publications";
import { languages, langPath, siteCopy, type Lang } from "../../../i18n";

export async function getStaticPaths() {
	const authors = await getAuthors("en");

	return languages.flatMap((lang) =>
		authors.map((author) => ({
			params: { lang, slug: author.slug },
		}))
	);
}

const lang = Astro.params.lang as Lang;
const t = siteCopy[lang];
const author = await getAuthor(Astro.params.slug as string, lang);

if (!author) {
	return Astro.redirect(langPath(lang, "/publications"), 302);
}

const authorPublications = await getPublicationsByAuthor(author.slug, lang);
---

<BaseLayout title={`${author.name} | CATALIZATOR`} description={author.bio} lang={lang}>
	<Header lang={lang} />
	<main>
		<section class="motion-section gradient-rule px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(18rem,0.28fr)]">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-purple)]">{t.publication.author}</p>
					<h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight tracking-[-0.045em] text-[var(--color-ink)] sm:text-5xl lg:text-6xl">
						{author.name}
					</h1>
				</div>
				<p class="self-end text-base leading-7 text-[var(--color-muted)]">
					{author.bio}
				</p>
			</div>
		</section>

		<section class="motion-section px-4 pb-16 sm:px-6 sm:pb-20 lg:px-8 lg:pb-24">
			<div class="mx-auto max-w-7xl">
				<div class="grid items-stretch gap-5 md:grid-cols-2 lg:grid-cols-3">
					{authorPublications.map((publication) => (
						<PublicationCard publication={publication} lang={lang} />
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer lang={lang} />
</BaseLayout>
