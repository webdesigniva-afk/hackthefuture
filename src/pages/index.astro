<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#FFFFFF" />
		<title>HTF | CHALLENGE</title>
		<script is:inline>
			(() => {
				const supportedLanguages = ["en", "bg"];
				const storageKey = "site-language";

				const getSavedLanguage = () => {
					try {
						const savedLanguage = localStorage.getItem(storageKey);
						return supportedLanguages.includes(savedLanguage) ? savedLanguage : null;
					} catch {
						return null;
					}
				};

				const getBrowserDefaultLanguage = () => {
					const browserLanguages = navigator.languages?.length ? navigator.languages : [navigator.language].filter(Boolean);
					const prefersBulgarian = browserLanguages.some((language) => language.toLowerCase().startsWith("bg"));

					return prefersBulgarian ? "bg" : "en";
				};

				const initialLanguage = getSavedLanguage() ?? getBrowserDefaultLanguage();
				window.location.replace(`/${initialLanguage}${window.location.search}${window.location.hash}`);
			})();
		</script>
	</head>
	<body>
		<a href="/en">English</a>
		<a href="/bg">Bulgarian</a>
	</body>
</html>
